<!doctype html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>배치 코드 자동 생성 시스템 & 재고 관리 / MES System</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <style>
        /* PDF 렌더링용 숨김 캔버스 */
        #pdf-container { 
            position: absolute; 
            left: -9999px; 
            top: 0; 
            width: 800px;
            background: white;
        }
        .tab-btn { transition: all 0.3s ease; }
        .tab-btn.active { border-bottom: 2px solid #2563eb; color: #2563eb; font-weight: bold; }
        .toggle-icon { transition: transform 0.3s ease; }
        .toggle-icon.open { transform: rotate(180deg); }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen font-sans relative overflow-x-hidden">
    
    <div class="max-w-7xl mx-auto px-6 pt-4 flex justify-end">
        <button onclick="toggleLang()" class="bg-gray-800 hover:bg-gray-700 text-white px-3 py-1.5 rounded shadow font-bold text-sm transition">
            ?? <span id="langBtnText">English</span>
        </button>
    </div>

    <div class="max-w-7xl mx-auto p-6">
        
        <div class="flex space-x-8 mb-6 border-b border-gray-300 overflow-x-auto whitespace-nowrap scrollbar-hide">
            <button onclick="switchTab('production')" id="tab-production" class="tab-btn active pb-2 text-lg text-gray-600 font-medium" data-i18n="tab_prod">생산 및 배치 생성</button>
            <button onclick="switchTab('inventory')" id="tab-inventory" class="tab-btn pb-2 text-lg text-gray-600 font-medium" data-i18n="tab_inv">재고 관리 (입출고)</button>
            <button onclick="switchTab('dashboard')" id="tab-dashboard" class="tab-btn pb-2 text-lg text-gray-600 font-medium" data-i18n="tab_dash">생산량 파악 및 통계</button>
            <button onclick="switchTab('workload')" id="tab-workload" class="tab-btn pb-2 text-lg text-gray-600 font-medium" data-i18n="tab_workload">업무 분담 파악</button>
            <button onclick="switchTab('blender')" id="tab-blender" class="tab-btn pb-2 text-lg text-gray-600 font-medium" data-i18n="tab_blender">블렌더 통계 (TB900)</button>
        </div>

        <div id="view-production" class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-4 space-y-6">
                <div class="bg-white p-6 rounded-xl shadow-md">
                    <h2 class="text-xl font-bold mb-4 text-gray-800" data-i18n="sys_setup">시스템 설정 및 입력</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_stock">Stock Code</label>
                            <input type="text" id="stockCode" class="mt-1 block w-full border border-gray-300 rounded-md p-2" data-i18n-ph="ph_stock" placeholder="예: RM-100" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_job">Job# (작업지시번호)</label>
                            <input type="text" id="prodJobNo" oninput="document.getElementById('statJobNo').innerText = this.value || '-'" class="mt-1 block w-full border border-gray-300 rounded-md p-2" data-i18n-ph="ph_job" placeholder="예: WO-2026-001" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_target">패킹 기준 양 (A Kg)</label>
                            <input type="number" id="targetSize" class="mt-1 block w-full border border-gray-300 rounded-md p-2" data-i18n-ph="ph_target" placeholder="예: 100" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_planned">총 계획 생산량 (Kg)</label>
                            <input type="number" id="plannedProd" class="mt-1 block w-full border border-gray-300 rounded-md p-2" data-i18n-ph="ph_planned" placeholder="예: 5000" />
                        </div>
                        <div class="bg-gray-50 p-3 rounded-md border border-gray-200 mt-2">
                            <label class="block text-sm font-bold text-gray-700 mb-2" data-i18n="lbl_batch_mode">배치 번호 부여 방식</label>
                            <div class="flex flex-col space-y-2">
                                <label class="flex items-center cursor-pointer">
                                    <input type="radio" name="batchMode" value="individual" class="mr-2 text-indigo-600 focus:ring-indigo-500">
                                    <span class="text-sm text-gray-700" data-i18n="opt_batch_ind">개별 배치 (B1, B2, B3 순차 증가)</span>
                                </label>
                                <label class="flex items-center cursor-pointer">
                                    <input type="radio" name="batchMode" value="grouped" class="mr-2 text-indigo-600 focus:ring-indigo-500" checked>
                                    <span class="text-sm text-gray-700 font-bold" data-i18n="opt_batch_grp">단일/묶음 배치 (동일 Job내 모두 같은 B#)</span>
                                </label>
                            </div>
                        </div>
                        <hr class="my-4" />
                        <div class="bg-blue-50 p-4 rounded-md">
                            <div class="flex justify-between items-center mb-2">
                                <label class="block text-sm font-bold text-blue-800" data-i18n="lbl_prev">이월된 부분 배치 (P_prev)</label>
                                <div class="space-x-1 flex">
                                    <input type="file" id="partialCsvInput" accept=".csv" class="hidden" onchange="importPartialCSV(event)" />
                                    <button onclick="document.getElementById('partialCsvInput').click()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-2 py-1 rounded text-xs font-bold shadow transition" data-i18n="btn_load_partial">잔량 CSV 로드</button>
                                    <button onclick="addManualPartial()" class="bg-blue-600 hover:bg-blue-700 text-white px-2 py-1 rounded text-xs font-bold shadow transition" data-i18n="btn_add_manual">+ 수동 추가</button>
                                </div>
                            </div>
                            <div id="partialsList" class="space-y-2 mb-2 max-h-32 overflow-y-auto pr-1"></div>
                            <div class="text-sm font-semibold text-blue-900 mt-2 border-t border-blue-200 pt-2">
                                <span data-i18n="lbl_current_partial">현재 보관 잔량:</span> <span id="totalPartialAmount" class="text-lg">0</span> Kg
                            </div>
                        </div>
                        <hr class="my-4" />
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_today">오늘의 날짜</label>
                                <button onclick="resetDailyCounter()" class="text-xs bg-gray-200 hover:bg-gray-300 text-gray-700 px-2 py-1 rounded shadow-sm transition font-bold" data-i18n="btn_reset_counter">번호 초기화</button>
                            </div>
                            <input type="date" id="prodDate" class="mt-1 block w-full border border-gray-300 rounded-md p-2" />
                        </div>
                        <div class="mt-4">
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_daily">당일 생산량 (B Kg)</label>
                            <input type="number" id="dailyProd" class="mt-1 block w-full border border-gray-300 rounded-md p-2" data-i18n-ph="ph_daily" placeholder="예: 200" />
                        </div>
                        <div class="flex space-x-2 mt-6">
                            <button id="generateBtn" onclick="generateBatches()" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-4 rounded-md shadow transition" data-i18n="btn_generate">배치 코드 생성</button>
                            <button id="unlockBtn" onclick="unlockGenerate()" class="hidden whitespace-nowrap bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 px-4 rounded-md shadow transition" data-i18n="btn_unlock">락 해제</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-8 space-y-6">
                <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                    <div class="bg-white p-4 rounded-xl shadow-md border-l-4 border-indigo-500">
                        <div class="text-xs text-gray-500 font-bold uppercase" data-i18n="stat_job">현재 작업 Job#</div>
                        <div class="text-xl font-bold text-gray-800 break-all" id="statJobNo">-</div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-md border-l-4 border-blue-500">
                        <div class="text-xs text-gray-500 font-bold uppercase" data-i18n="stat_planned">총 계획 생산량</div>
                        <div class="text-2xl font-bold text-gray-800" id="statPlanned">0 <span class="text-sm font-normal text-gray-500">Kg</span></div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-md border-l-4 border-green-500">
                        <div class="text-xs text-gray-500 font-bold uppercase" data-i18n="stat_actual">실제 총 생산량</div>
                        <div class="text-2xl font-bold text-gray-800" id="statActual">0 <span class="text-sm font-normal text-gray-500">Kg</span></div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-md border-l-4 border-orange-500">
                        <div class="text-xs text-gray-500 font-bold uppercase" data-i18n="stat_remain">남은 생산량</div>
                        <div class="text-2xl font-bold text-gray-800" id="statRemaining">0 <span class="text-sm font-normal text-gray-500">Kg</span></div>
                    </div>
                    <div class="bg-white p-4 rounded-xl shadow-md border-l-4 border-purple-500">
                        <div class="text-xs text-gray-500 font-bold uppercase" data-i18n="stat_partial">보관 중인 잔량</div>
                        <div class="text-2xl font-bold text-gray-800" id="statPartial">0 <span class="text-sm font-normal text-gray-500">Kg</span></div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-md min-h-[500px] flex flex-col">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-xl font-bold text-gray-800" data-i18n="title_history">생산 기록 (Production History)</h2>
                        <div class="space-x-2 flex items-center flex-wrap gap-y-2 justify-end">
                            <button onclick="addAllToInventory()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_inbound">입고(Add Inventory)</button>
                            <button onclick="undoLast()" class="bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_undo">실행 취소</button>
                            <button onclick="resetAll()" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_reset">초기화</button>
                            
                            <input type="file" id="csvFileInput" accept=".csv" class="hidden" onchange="importCSV(event)" />
                            <button onclick="document.getElementById('csvFileInput').click()" class="bg-teal-600 hover:bg-teal-700 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_load_csv">CSV 불러오기</button>
                            
                            <button onclick="exportCSV()" class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_export_csv">백업 (CSV)</button>
                            <button onclick="exportPDF()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_export_pdf">리포트 (PDF)</button>
                        </div>
                    </div>
                    <div id="historyContainer" class="space-y-4 overflow-y-auto pr-1"></div>
                </div>
            </div>
        </div>

        <div id="view-inventory" class="hidden space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-red-500">
                    <h2 class="text-xl font-bold mb-4 text-gray-800" data-i18n="title_issue">자재 출고 (Material Issue)</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_sel_stock">Stock Code 선택</label>
                            <select id="issueStockCode" onchange="updateBatchDropdown()" class="mt-1 block w-full border border-gray-300 rounded-md p-2 bg-gray-50 focus:ring-red-500 focus:border-red-500">
                                <option value="" data-i18n="opt_sel_stock">Stock Code를 선택하세요</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_sel_batch">Batch Code 선택</label>
                            <select id="issueBatchCode" onchange="updateMaxIssueAmount()" class="mt-1 block w-full border border-gray-300 rounded-md p-2 bg-gray-50 focus:ring-red-500 focus:border-red-500" disabled>
                                <option value="" data-i18n="opt_first_stock">먼저 Stock Code를 선택하세요</option>
                            </select>
                        </div>
                        <div>
                            <div class="flex justify-between items-end mb-1">
                                <label class="block text-sm font-medium text-gray-700" data-i18n="lbl_job_multi">Job# (다중 입력 가능)</label>
                                <button onclick="addIssueJobInput()" class="text-xs bg-red-50 text-red-700 hover:bg-red-100 px-2 py-1 rounded font-bold transition border border-red-200" data-i18n="btn_add_job">+ Job 추가</button>
                            </div>
                            <div id="issueJobContainer" class="space-y-2">
                                <div class="flex items-center space-x-2">
                                    <input type="text" class="issue-job-input flex-grow block w-full border border-gray-300 rounded-md p-2 focus:ring-red-500 focus:border-red-500" data-i18n-ph="ph_job" placeholder="예: WO-2026-001" />
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700"><span data-i18n="lbl_amount">출고량 (Kg)</span> <span id="maxIssueLabel" class="text-xs text-blue-600 font-bold ml-2"></span></label>
                            <input type="number" id="issueAmount" class="mt-1 block w-full border border-gray-300 rounded-md p-2 focus:ring-red-500 focus:border-red-500" data-i18n-ph="ph_issue" placeholder="출고할 양 입력" />
                        </div>
                        <button onclick="issueMaterial()" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-md shadow transition text-lg mt-2" data-i18n="btn_execute_issue">
                            Material Issue (출고 실행)
                        </button>
                    </div>
                </div>

                <div class="lg:col-span-2 bg-white p-6 rounded-xl shadow-md border-t-4 border-blue-500 flex flex-col">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-xl font-bold text-gray-800" data-i18n="title_inv_status">현재 창고 재고 현황</h2>
                        <div class="space-x-2">
                            <button onclick="deleteSelectedInventory()" class="bg-orange-500 hover:bg-orange-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_del_sel">선택 항목 삭제</button>
                            <button onclick="cleanupDepletedInventory()" class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_clear_depleted">소진된 재고 정리</button>
                            <button onclick="clearAllInventory()" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition" data-i18n="btn_del_all_inv">전체 삭제</button>
                        </div>
                    </div>
                    <div class="overflow-x-auto overflow-y-auto flex-grow border border-gray-200 rounded-lg max-h-[400px]">
                        <table class="min-w-full text-left text-sm whitespace-nowrap">
                            <thead class="uppercase tracking-wider border-b-2 border-gray-300 bg-gray-100 sticky top-0 z-10">
                                <tr>
                                    <th class="px-4 py-3 w-10 text-center"><input type="checkbox" id="selectAllinv" onclick="toggleAll('inv')" class="rounded text-indigo-600 focus:ring-indigo-500 cursor-pointer"></th>
                                    <th class="px-4 py-3" data-i18n="th_date">입고 날짜</th>
                                    <th class="px-4 py-3" data-i18n="th_stock">Stock Code</th>
                                    <th class="px-4 py-3" data-i18n="th_batch">Batch Code</th>
                                    <th class="px-4 py-3 text-right" data-i18n="th_remain">잔량 (Kg)</th>
                                    <th class="px-4 py-3 text-center" data-i18n="th_status">Status</th>
                                </tr>
                            </thead>
                            <tbody id="inventoryTableBody" class="divide-y divide-gray-200"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-gray-700 flex flex-col">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold text-gray-800" data-i18n="title_trans">입출고 기록 (Transaction History)</h2>
                    <div class="space-x-2">
                        <button onclick="deleteSelectedTransactions()" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded text-sm font-bold shadow transition" data-i18n="btn_del_sel">선택 항목 삭제</button>
                        <button onclick="exportInventoryHistoryCSV()" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded text-sm font-bold shadow transition" data-i18n="btn_dl_history">히스토리 CSV 다운로드</button>
                        <button onclick="clearTransactionHistory()" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded text-sm font-bold shadow transition" data-i18n="btn_clear_history">기록 전체 삭제</button>
                    </div>
                </div>
                <div class="overflow-x-auto overflow-y-auto border border-gray-200 rounded-lg max-h-[300px]">
                    <table class="min-w-full text-left text-sm whitespace-nowrap">
                        <thead class="uppercase tracking-wider border-b-2 border-gray-300 bg-gray-100 sticky top-0 z-10">
                            <tr>
                                <th class="px-4 py-3 w-10 text-center"><input type="checkbox" id="selectAlltrx" onclick="toggleAll('trx')" class="rounded text-indigo-600 focus:ring-indigo-500 cursor-pointer"></th>
                                <th class="px-4 py-3" data-i18n="th_time">시간</th>
                                <th class="px-4 py-3" data-i18n="th_type">유형</th>
                                <th class="px-4 py-3" data-i18n="th_stock">Stock Code</th>
                                <th class="px-4 py-3" data-i18n="th_batch">Batch Code</th>
                                <th class="px-4 py-3" data-i18n="th_job_col">Job#</th>
                                <th class="px-4 py-3 text-right" data-i18n="th_amt">변동량 (Kg)</th>
                                <th class="px-4 py-3" data-i18n="th_remarks">비고</th>
                            </tr>
                        </thead>
                        <tbody id="transactionTableBody" class="divide-y divide-gray-200"></tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div id="view-dashboard" class="hidden space-y-6">
            <div class="bg-white p-4 rounded-xl shadow-md flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center space-x-4">
                    <h2 class="text-lg font-bold text-gray-800" data-i18n="dash_filter_title">통계 기간 설정</h2>
                    <div class="flex space-x-1 bg-gray-100 p-1 rounded-lg">
                        <button onclick="setDashPeriod(7)" class="period-btn px-4 py-1.5 text-sm rounded-md bg-transparent text-gray-600 hover:bg-white hover:shadow transition font-medium" id="p_7">1주</button>
                        <button onclick="setDashPeriod(30)" class="period-btn px-4 py-1.5 text-sm rounded-md bg-transparent text-gray-600 hover:bg-white hover:shadow transition font-medium" id="p_30">1달</button>
                        <button onclick="setDashPeriod(90)" class="period-btn px-4 py-1.5 text-sm rounded-md bg-transparent text-gray-600 hover:bg-white hover:shadow transition font-medium" id="p_90">3달</button>
                        <button onclick="setDashPeriod(365)" class="period-btn px-4 py-1.5 text-sm rounded-md bg-transparent text-gray-600 hover:bg-white hover:shadow transition font-medium" id="p_365">1년</button>
                        <button onclick="setDashPeriod(0)" class="period-btn px-4 py-1.5 text-sm rounded-md bg-white shadow text-indigo-700 font-bold transition" id="p_0">전체(Overall)</button>
                    </div>
                </div>
                
                <div class="flex items-center space-x-3 bg-teal-50 p-2 rounded-lg border border-teal-100">
                    <span class="text-sm text-teal-800 font-medium" data-i18n="dash_load_info">데이터가 없나요?</span>
                    <button onclick="document.getElementById('csvFileInput').click()" class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-1.5 rounded-md text-sm font-bold shadow-sm transition">
                        <span data-i18n="btn_load_csv">CSV 불러오기</span>
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
                <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-indigo-500 flex flex-col justify-center">
                    <div class="text-sm text-gray-500 font-bold uppercase" data-i18n="dash_total_prod">누적 총 생산 중량</div>
                    <div class="text-3xl font-black text-gray-800 mt-2" id="dashTotalProd">0 <span class="text-lg font-normal text-gray-500">Kg</span></div>
                </div>
                <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-blue-500 flex flex-col justify-center">
                    <div class="text-sm text-gray-500 font-bold uppercase" data-i18n="dash_product_types">생산된 품목(Product) 수</div>
                    <div class="text-3xl font-black text-gray-800 mt-2" id="dashTotalTypes">0 <span class="text-lg font-normal text-gray-500" id="dashTypeUnit">종류</span></div>
                </div>
                <div class="bg-gray-50 p-6 rounded-xl shadow-inner border border-gray-200 relative overflow-hidden text-gray-400 flex flex-col justify-center">
                    <div class="absolute top-2 right-2 bg-yellow-400 text-yellow-900 text-[10px] font-bold px-2 py-0.5 rounded italic">Coming Soon</div>
