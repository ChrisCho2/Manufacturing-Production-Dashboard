        function translateStatus(raw) {
            if (raw.includes('가용') || raw === 'Available') return t('status_Available');
            if (raw.includes('부분') || raw === 'Partial') return t('status_Partial');
            if (raw.includes('소진') || raw === 'Depleted') return t('status_Depleted');
            return raw;
        }

        function translateRemark(raw) {
            if (raw.includes('신규 배치') || raw === 'New batch inbound') return t('rem_inbound');
            if (raw.includes('자재 출고 (Job# 미지정)') || raw === 'Material issue (No Job#)') return t('rem_issue_nojob');
            let match = raw.match(/Job#:\s*(.+)\)/);
            if (match) return `${t('rem_issue_job')} ${match[1]})`;
            if (raw.includes('자재 출고') || raw === 'Material issue') return t('rem_issue');
            return raw;
        }

        function parseCSVRow(str) {
            const result = [];
            let curr = '';
            let inQuotes = false;
            for (let i = 0; i < str.length; i++) {
                const char = str[i];
                if (char === '"') {
                    if (inQuotes && str[i + 1] === '"') { curr += '"'; i++; } 
                    else { inQuotes = !inQuotes; }
                } else if (char === ',' && !inQuotes) {
                    result.push(curr); curr = '';
                } else { curr += char; }
            }
            result.push(curr);
            return result;
        }

        // ======= [추가됨: 캐나다 BC주 법정 공휴일 판별 함수] =======
        function isBCHoliday(date) {
            const y = date.getFullYear();
            const m = date.getMonth() + 1; // 1월이 1
            const d = date.getDate();
            const dayOfWeek = date.getDay(); // 0: 일요일, 1: 월요일 ...

            // 1. 날짜가 고정된 공휴일
            if (m === 1 && d === 1) return true;   // New Year's Day
            if (m === 7 && d === 1) return true;   // Canada Day
            if (m === 9 && d === 30) return true;  // National Day for Truth and Reconciliation
            if (m === 11 && d === 11) return true; // Remembrance Day
            if (m === 12 && d === 25) return true; // Christmas Day
            if (m === 12 && d === 26) return true; // Boxing Day (추가됨)

            // 2. 요일 기반으로 변동되는 공휴일
            // Family Day: 2월 셋째 주 월요일 (15일 ~ 21일 사이의 월요일)
            if (m === 2 && dayOfWeek === 1 && d >= 15 && d <= 21) return true;
            // Victoria Day: 5월 25일 직전의 월요일 (18일 ~ 24일 사이의 월요일)
            if (m === 5 && dayOfWeek === 1 && d >= 18 && d <= 24) return true;
            // BC Day: 8월 첫째 주 월요일 (1일 ~ 7일 사이의 월요일)
            if (m === 8 && dayOfWeek === 1 && d >= 1 && d <= 7) return true;
            // Labour Day: 9월 첫째 주 월요일
            if (m === 9 && dayOfWeek === 1 && d >= 1 && d <= 7) return true;
            // Thanksgiving Day: 10월 둘째 주 월요일 (8일 ~ 14일 사이의 월요일)
            if (m === 10 && dayOfWeek === 1 && d >= 8 && d <= 14) return true;

            // 3. Good Friday (부활절 기준이라 매년 바뀜. 2024~2030년 하드코딩)
            const goodFridays = ['2024-03-29', '2025-04-18', '2026-04-03', '2027-03-26', '2028-04-14', '2029-03-30', '2030-04-19'];
            const dateStr = `${y}-${m.toString().padStart(2, '0')}-${d.toString().padStart(2, '0')}`;
            if (goodFridays.includes(dateStr)) return true;

            return false;
        }

        // ======= [수정됨: 주말/공휴일 및 점심시간(1시간) 제외 작업 시간 계산] =======
        // ======= [수정됨: 동일 날짜 작업은 9~17시 제약 해제, 다중 날짜는 유지] =======
        function calcWorkingMins(startStr, endStr, removeBounds = false) {
            const start = new Date(startStr);
            const end = new Date(endStr);
            
            if (isNaN(start.getTime()) || isNaN(end.getTime()) || start > end) return null;

            let currentDay = new Date(start.getFullYear(), start.getMonth(), start.getDate());
            let endDay = new Date(end.getFullYear(), end.getMonth(), end.getDate());
            
            let totalMins = 0;

            while (currentDay <= endDay) {
                const isWeekend = currentDay.getDay() === 0 || currentDay.getDay() === 6;
                const isHoliday = isBCHoliday(currentDay);

                if (!isWeekend && !isHoliday) {
                    let dayStart = new Date(currentDay);
                    let dayEnd = new Date(currentDay);

                    // [핵심 변경] 당일치기 작업이면 바운더리를 00시~23시59분으로 확장
                    if (removeBounds) {
                        dayStart.setHours(0, 0, 0, 0); 
                        dayEnd.setHours(23, 59, 59, 999);  
                    } else {
                        // 여러 날에 걸친 작업이면 기존처럼 9~17시로 고정
                        dayStart.setHours(9, 0, 0, 0); 
                        dayEnd.setHours(17, 0, 0, 0);  
                    }

                    let calcStart = dayStart;
                    let calcEnd = dayEnd;

                    if (currentDay.getTime() === new Date(start.getFullYear(), start.getMonth(), start.getDate()).getTime()) {
                        calcStart = start > dayStart ? start : dayStart;
                    }
                    if (currentDay.getTime() === endDay.getTime()) {
                        calcEnd = end < dayEnd ? end : dayEnd;
                    }

                    if (calcStart < calcEnd) {
                        let boundedStart = Math.max(calcStart.getTime(), dayStart.getTime());
                        let boundedEnd = Math.min(calcEnd.getTime(), dayEnd.getTime());
                        
                        let mins = (boundedEnd - boundedStart) / 60000;

                        // 점심시간(12:00 ~ 13:00) 차감 로직은 동일하게 유지
                        let lunchStart = new Date(currentDay).setHours(12, 0, 0, 0);
                        let lunchEnd = new Date(currentDay).setHours(13, 0, 0, 0);
                        let overlapLunchStart = Math.max(boundedStart, lunchStart);
                        let overlapLunchEnd = Math.min(boundedEnd, lunchEnd);
                        
                        if (overlapLunchStart < overlapLunchEnd) {
                            mins -= (overlapLunchEnd - overlapLunchStart) / 60000;
                        }

                        if (mins > 0) totalMins += mins;
                    }
                }
                currentDay.setDate(currentDay.getDate() + 1);
            }
            return totalMins;
        }

        function formatMins(m) {
            if (m === null || isNaN(m)) return "-";
            m = Math.round(m);
            
            const hrs = Math.floor(m / 60);
            const mins = m % 60;
            
            const hrsStr = hrs.toString().padStart(2, '0');
            const minsStr = mins.toString().padStart(2, '0');
            
            return `${hrsStr}:${minsStr}`;
        }
        
