        function buildCsvRow(arr) {
            return arr.map((val) => {
                let str = String(val);
                if (str.includes(",") || str.includes('"') || str.includes("\n")) str = `"${str.replace(/"/g, '""')}"`;
                return str;
            }).join(",");
        }

        function exportCSV() {
            let csvContent = "data:text/csv;charset=utf-8,\uFEFF";
            csvContent += buildCsvRow(["Type", "Timestamp", "Date", "StockCode", "TargetSize", "DailyProdInput", "Summary", "RawJSON_Data(DoNotEdit)"]) + "\n";
            
            const globalState = { 
                plannedProd: state.plannedProd, actualProd: state.actualProd, targetSize: state.targetSize, 
                partials: state.partials, counters: state.counters, inventory: state.inventory, transactions: state.transactions,
                workorders: state.workorders, timeTracks: state.timeTracks, blenderData: state.blenderData 
            };
            csvContent += buildCsvRow(["GLOBAL_STATE", "", "", "", "", "", "System Backup Data", JSON.stringify(globalState)]) + "\n";
            
            state.history.forEach((rec) => {
                const summary = rec.batches.map((b) => b.code).join(" / ");
                csvContent += buildCsvRow(["HISTORY_RECORD", rec.timestamp, rec.date, rec.stockCode || "", state.targetSize, rec.dailyProdInput, summary, JSON.stringify(rec)]) + "\n";
            });
            
            const link = document.createElement("a"); 
            link.setAttribute("href", encodeURI(csvContent));
            link.setAttribute("download", `System_Backup_${new Date().toISOString().slice(0, 10)}.csv`);
            document.body.appendChild(link); link.click(); document.body.removeChild(link);
        }

        function importCSV(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                const lines = e.target.result.split("\n");
                let newState = { stockCode: "", targetSize: 0, plannedProd: 0, actualProd: 0, partials: [], history: [], counters: {}, inventory: [], transactions: [], workorders: [], timeTracks: [], blenderData: null };
                
                for (let i = 1; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line) continue;
                    
                    const cols = parseCSVRow(line); 
                    
                    if (cols[0] === "GLOBAL_STATE" && cols[7]) {
                        try {
                            const globalData = JSON.parse(cols[7]);
                            newState.plannedProd = globalData.plannedProd || 0; 
                            newState.actualProd = globalData.actualProd || 0;
                            newState.targetSize = globalData.targetSize || 0; 
                            newState.partials = globalData.partials || [];
                            newState.counters = globalData.counters || {}; 
                            newState.inventory = globalData.inventory || []; 
                            newState.transactions = globalData.transactions || []; 
                            newState.workorders = globalData.workorders || []; 
                            newState.timeTracks = globalData.timeTracks || [];
                            newState.blenderData = globalData.blenderData || null; 
                        } catch (err) {}
                    } else if (cols[0] === "HISTORY_RECORD" && cols[7]) {
                        try {
                            const rec = JSON.parse(cols[7]); 
                            newState.history.push(rec);
                            if (!newState.stockCode && rec.stockCode) newState.stockCode = rec.stockCode;
                        } catch (err) {}
                    }
                }

                const calcActual = newState.history.reduce((sum, rec) => sum + (Number(rec.dailyProdInput) || 0), 0);
                if (calcActual > 0 && newState.actualProd === 0) newState.actualProd = calcActual;

                if (newState.history.length > 0 || newState.partials.length > 0 || newState.inventory.length > 0 || newState.workorders.length > 0 || newState.timeTracks.length > 0 || newState.blenderData) {
                    state = newState;
                    document.getElementById("stockCode").value = state.stockCode;
                    document.getElementById("targetSize").value = state.targetSize;
                    document.getElementById("plannedProd").value = state.plannedProd;
                    saveState(); 
                    alert(getMsg("성공적으로 백업 데이터를 불러왔습니다.", "Backup data loaded successfully."));
                    
                    if (document.getElementById("view-workload") && !document.getElementById("view-workload").classList.contains("hidden")) {
                        renderWorkloadView();
                        renderTimeTracks();
                    }
                    if (document.getElementById("view-blender") && !document.getElementById("view-blender").classList.contains("hidden")) {
                        renderBlenderView();
                    }
                } else { 
                    alert(getMsg("유효한 백업 데이터가 없습니다.", "Invalid CSV data.")); 
                }
                event.target.value = "";
            };
            reader.readAsText(file);
        }

