        async function importWorkOrderCSV(event) {
            const files = event.target.files;
            if (!files || files.length === 0) return;

            for (let f = 0; f < files.length; f++) {
                const file = files[f];
                if (!file.name.toLowerCase().endsWith('.csv')) {
                    alert(getMsg(`지원하지 않는 파일 형식입니다: ${file.name}`, `Unsupported file format: ${file.name}`));
                    continue;
                }
                const text = await file.text();
                
                const lines = text.split(/\r?\n/);
                let woData = { id: 'wo_' + Date.now() + Math.random().toString(36).substr(2, 5), job: '-', date: '-', op: '-', members: [], source: file.name };
                let isTeamSection = false;

                for (let i = 0; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line) continue;
                    
                    const cols = parseCSVRow(line);

                    if (cols[0] === "Job") woData.job = cols[1];
                    if (cols[0] === "Date") woData.date = cols[1];
                    if (cols[0] === "Operation") woData.op = cols[1];

                    if (cols[0] && cols[0].toUpperCase().includes("TEAM ASSIGNMENTS")) {
                        isTeamSection = true;
                        continue;
                    }

                    if (isTeamSection) {
                        if (cols[0] === "Team Member") continue; 
                        
                        if (cols.length < 2 || (cols[0].toUpperCase() === cols[0] && cols[0].length > 5 && !cols[1])) {
                            isTeamSection = false;
                            continue;
                        }
                        
                        if (cols[0] && cols[1]) {
                            const rawTasks = cols[1].split(';').map(t => t.trim()).filter(Boolean);
                            if (rawTasks.length > 0) {
                                woData.members.push({ name: cols[0], tasks: rawTasks });
                            }
                        }
                    }
                }

                if (woData.members.length > 0) {
                    addWorkOrderToState(woData);
                } else {
                    alert(getMsg(`파일 [${file.name}] 에 업무 분담 데이터가 없습니다.`, `No task data found in [${file.name}].`));
                }
            }
            event.target.value = ""; 
        }

        function addWorkOrderToState(woData) {
            if (!state.workorders) state.workorders = [];
            const existingIdx = state.workorders.findIndex(wo => wo.job === woData.job && wo.job !== "-");
            if (existingIdx !== -1) {
                if (confirm(getMsg(`Job# [${woData.job}] 의 분석 데이터가 이미 존재합니다. 덮어쓰시겠습니까?`, `Job# [${woData.job}] already exists. Overwrite?`))) {
                    state.workorders[existingIdx] = woData;
                } else return;
            } else {
                state.workorders.push(woData);
            }
            saveState();
            renderWorkloadView();
        }

        function removeWorkOrder(index) {
            if (confirm(getMsg("이 작업지시서의 분석 데이터를 누적 목록에서 삭제하시겠습니까?", "Delete this Work Order from the list?"))) {
                state.workorders.splice(index, 1);
                saveState();
                renderWorkloadView();
            }
        }

        function renderWorkloadView() {
            const container = document.getElementById("view-workload");
            if (!container || container.classList.contains("hidden")) return;

            let filteredWOs = [...(state.workorders || [])];
            
            if (wlPeriodDays > 0) {
                const cutoffDate = new Date();
                cutoffDate.setDate(cutoffDate.getDate() - wlPeriodDays);
                cutoffDate.setHours(0,0,0,0);
                
                filteredWOs = filteredWOs.filter(wo => {
                    const d = new Date(wo.date);
                    if (isNaN(d.getTime())) return true; 
                    d.setHours(0,0,0,0);
                    return d >= cutoffDate;
                });
            }

            const listEl = document.getElementById("wl-loaded-list");
            const emptyState = document.getElementById("workloadEmptyState");
            const content = document.getElementById("workloadContentArea");

            if (listEl) {
                listEl.innerHTML = filteredWOs.map((wo) => {
                    const originalIdx = state.workorders.indexOf(wo);
                    return `
                    <div class="flex justify-between items-center p-3 bg-gray-50 border border-gray-200 rounded-lg mb-2 shadow-sm transition hover:shadow">
                        <div>
                            <div class="font-bold text-indigo-700 text-sm">Job: ${wo.job}</div>
                            <div class="text-xs text-gray-500 font-mono mt-0.5">${wo.date} | ${wo.op}</div>
                        </div>
                        <button onclick="removeWorkOrder(${originalIdx})" class="text-gray-400 hover:text-red-600 bg-white border border-gray-200 hover:bg-red-50 rounded px-2 py-1 transition text-xs font-bold shadow-sm">X</button>
                    </div>
                `}).join("");
                
                if (filteredWOs.length === 0) listEl.innerHTML = `<div class="text-gray-400 text-sm py-4 text-center">No loaded files</div>`;
            }

            if (!filteredWOs || filteredWOs.length === 0) {
                emptyState.classList.remove("hidden");
                content.classList.add("hidden");
                return;
            }

            emptyState.classList.add("hidden");
            content.classList.remove("hidden");

            let memberMap = {};
            let memberTasksMap = {}; // 작업자별 고유 업무 저장
            let allUniqueTasks = new Set(); // 컬러 매핑을 위한 전체 고유 업무 저장
            let totalTasks = 0;

            filteredWOs.forEach(wo => {
                wo.members.forEach(m => {
                    if (!memberMap[m.name]) {
                        memberMap[m.name] = 0;
                        memberTasksMap[m.name] = new Set();
                    }
                    memberMap[m.name] += m.tasks.length;
                    m.tasks.forEach(task => {
                        memberTasksMap[m.name].add(task);
                        allUniqueTasks.add(task);
                    });
                    totalTasks += m.tasks.length;
                });
            });

            const labels = Object.keys(memberMap).sort((a,b) => memberMap[b] - memberMap[a]);
            const data = labels.map(k => memberMap[k]);
            const percentages = data.map(v => totalTasks > 0 ? ((v / totalTasks) * 100).toFixed(1) : 0);

            const tbody = document.getElementById("workloadTableBody");
            if (tbody) {
                tbody.innerHTML = labels.map((name, i) => `
                    <tr class="hover:bg-gray-50 transition border-b border-gray-100">
                        <td class="px-4 py-3 font-bold text-gray-800">${name}</td>
                        <td class="px-4 py-3 text-center"><span class="bg-blue-100 text-blue-800 font-bold px-3 py-1 rounded-full text-xs">${data[i]}</span></td>
                        <td class="px-4 py-3 text-right font-black text-indigo-600">${percentages[i]}%</td>
                    </tr>
                `).join("");
                
                tbody.innerHTML += `
                    <tr class="bg-gray-100 border-t-2 border-gray-300">
                        <td class="px-4 py-3 font-black text-gray-800 uppercase">Total</td>
                        <td class="px-4 py-3 text-center font-black text-gray-800">${totalTasks}</td>
                        <td class="px-4 py-3 text-right font-black text-indigo-600">100%</td>
                    </tr>
                `;
            }

            // --- 컬러 팔레트 생성 (업무별 일관된 색상 부여) ---
            const taskColorMap = {};
            const colorPalette = [
                'bg-red-100 text-red-800 border-red-200',
                'bg-blue-100 text-blue-800 border-blue-200',
                'bg-green-100 text-green-800 border-green-200',
                'bg-yellow-100 text-yellow-800 border-yellow-200',
                'bg-purple-100 text-purple-800 border-purple-200',
                'bg-pink-100 text-pink-800 border-pink-200',
                'bg-indigo-100 text-indigo-800 border-indigo-200',
                'bg-teal-100 text-teal-800 border-teal-200',
                'bg-orange-100 text-orange-800 border-orange-200'
            ];
            
            let colorIndex = 0;
            allUniqueTasks.forEach(task => {
                taskColorMap[task] = colorPalette[colorIndex % colorPalette.length];
                colorIndex++;
            });

            // --- 새 테이블(작업자별 할당 업무 상세) 렌더링 ---
            const detailsTbody = document.getElementById("workerTaskDetailsBody");
            if (detailsTbody) {
                detailsTbody.innerHTML = labels.map(name => {
                    // 각 업무를 색상이 지정된 둥근 뱃지로 변환
                    const tasksHtml = Array.from(memberTasksMap[name]).map(task => 
                        `<span class="inline-block px-3 py-1 mt-1 mr-1 rounded-full text-xs font-bold border ${taskColorMap[task]} shadow-sm">${task}</span>`
                    ).join("");

                    return `
                        <tr class="hover:bg-gray-50 transition border-b border-gray-100">
                            <td class="px-4 py-4 font-bold text-gray-800 align-middle">${name}</td>
                            <td class="px-4 py-3 flex flex-wrap gap-1">${tasksHtml}</td>
                        </tr>
                    `;
                }).join("");
            }

            if (workloadChartInstance) workloadChartInstance.destroy();
            const ctx = document.getElementById('workloadChart').getContext('2d');
            workloadChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: t('th_task_count') || 'Assigned Tasks',
                        data: data,
                        backgroundColor: 'rgba(79, 70, 229, 0.7)',
                        borderColor: 'rgba(79, 70, 229, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let val = context.raw;
                                    let pct = totalTasks > 0 ? ((val / totalTasks) * 100).toFixed(1) : 0;
                                    return `${val} Tasks (${pct}%)`;
                                }
                            }
                        }
                    }
                }
            });
            
            setTimeout(() => { initResizableColumns(); }, 50);
        }

