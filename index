        // ==========================================
        // Column Resizing Logic (동적 컬럼 크기 조절)
        // ==========================================
        function initResizableColumns() {
            const tables = document.querySelectorAll('table');
            tables.forEach(table => {
                const cols = table.querySelectorAll('th');
                [].forEach.call(cols, function (col) {
                    // 이미 리사이저가 추가되어 있으면 패스
                    if(col.querySelector('.resizer')) return;
                    
                    const resizer = document.createElement('div');
                    resizer.classList.add('resizer');
                    resizer.style.width = '6px';
                    resizer.style.height = '100%';
                    resizer.style.position = 'absolute';
                    resizer.style.right = '0';
                    resizer.style.top = '0';
                    resizer.style.cursor = 'col-resize';
                    resizer.style.userSelect = 'none';
                    resizer.style.zIndex = '1';
                    
                    // 호버 효과를 위한 CSS 클래스 연동
                    resizer.addEventListener('mouseenter', () => resizer.style.backgroundColor = 'rgba(99, 102, 241, 0.5)');
                    resizer.addEventListener('mouseleave', () => resizer.style.backgroundColor = 'transparent');
                    
                    col.style.position = 'relative';
                    col.appendChild(resizer);

                    let x = 0;
                    let w = 0;

                    const mouseDownHandler = function (e) {
                        x = e.clientX;
                        const styles = window.getComputedStyle(col);
                        w = parseInt(styles.width, 10);

                        document.addEventListener('mousemove', mouseMoveHandler);
                        document.addEventListener('mouseup', mouseUpHandler);
                        resizer.style.backgroundColor = 'rgba(99, 102, 241, 1)';
                    };

                    const mouseMoveHandler = function (e) {
                        const dx = e.clientX - x;
                        col.style.width = `${w + dx}px`;
                    };

                    const mouseUpHandler = function () {
                        document.removeEventListener('mousemove', mouseMoveHandler);
                        document.removeEventListener('mouseup', mouseUpHandler);
                        resizer.style.backgroundColor = 'transparent';
                    };

                    resizer.addEventListener('mousedown', mouseDownHandler);
                });
            });
        }

