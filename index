                saveState();
                renderBlenderView();
            }
        }

        function renderBlenderView() {
            const container = document.getElementById("view-blender");
            if (!container) return; 

            const emptyState = document.getElementById("blenderEmptyState");
            const contentArea = document.getElementById("blenderContentArea");

            if (!state.blenderData || Object.keys(state.blenderData).length === 0) {
                if (emptyState) emptyState.classList.remove("hidden");
                if (contentArea) contentArea.classList.add("hidden");
                return;
            }

            if (emptyState) emptyState.classList.add("hidden");
            if (contentArea) contentArea.classList.remove("hidden");

            let totalSetAll = 0;
            let totalActAll = 0;
            
            for (let comp in state.blenderData) {
                const data = state.blenderData[comp];
                totalSetAll += data.sets.reduce((a, b) => a + b, 0);
                totalActAll += data.acts.reduce((a, b) => a + b, 0);
            }

            const tbody = document.getElementById("blenderTableBody");
            let tableHtml = "";

            const labels = [];
            const setRatiosArr = [];
            const actRatiosArr = [];
            const accuraciesArr = [];

            for (let comp in state.blenderData) {
                const data = state.blenderData[comp];
                if (data.sets.length === 0) continue;

                const sumSet = data.sets.reduce((a, b) => a + b, 0);
                const sumAct = data.acts.reduce((a, b) => a + b, 0);
                
                const setRatio = totalSetAll > 0 ? (sumSet / totalSetAll) * 100 : 0;
                const actRatio = totalActAll > 0 ? (sumAct / totalActAll) * 100 : 0;
                const ratioDiff = actRatio - setRatio;

                const accuracy = sumSet > 0 ? (sumAct / sumSet) * 100 : 0;
                const errorVsSet = sumSet > 0 ? Math.abs(sumAct - sumSet) / sumSet * 100 : 0;
                const isValid = errorVsSet < 0.05; 
                
                labels.push(comp);
                setRatiosArr.push(setRatio.toFixed(2));
                actRatiosArr.push(actRatio.toFixed(2));
                accuraciesArr.push(accuracy.toFixed(3));

                let diffColorClass = "text-gray-600";
                if (ratioDiff > 0) diffColorClass = "text-green-600";
                else if (ratioDiff < 0) diffColorClass = "text-red-500";

                let diffWeightClass = Math.abs(ratioDiff) >= 0.1 ? "font-black" : "font-medium";

                tableHtml += `
                    <tr class="hover:bg-teal-50 transition border-b border-teal-100">
                        <td class="px-4 py-3 font-black text-gray-800">${comp}</td>
                        <td class="px-4 py-3 text-right font-mono text-gray-600">${sumSet.toFixed(2)}</td>
                        <td class="px-4 py-3 text-right font-mono text-teal-700 font-bold">${sumAct.toFixed(2)}</td>
                        <td class="px-4 py-3 text-right font-mono text-gray-600">${setRatio.toFixed(3)}%</td>
                        <td class="px-4 py-3 text-right font-mono text-indigo-600 font-bold">${actRatio.toFixed(3)}%</td>
                        <td class="px-4 py-3 text-right font-mono ${diffColorClass} ${diffWeightClass}">${ratioDiff > 0 ? '+' : ''}${ratioDiff.toFixed(3)}%</td>
                        <td class="px-4 py-3 text-right font-mono text-gray-800 font-bold">${accuracy.toFixed(3)}%</td>
                        <td class="px-4 py-3 text-center font-bold ${isValid ? 'text-green-600' : 'text-red-500'}">
                            ${isValid ? '? Pass' : '? Fail'}
                        </td>
                    </tr>
                `;
            }
            if (tbody) tbody.innerHTML = tableHtml;

            if (window.blenderBarChartInst && typeof window.blenderBarChartInst.destroy === 'function') {
                window.blenderBarChartInst.destroy();
            }
            const ctxBarEl = document.getElementById('blenderBarChart');
            if (ctxBarEl) {
                window.blenderBarChartInst = new Chart(ctxBarEl.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Set Ratio (%)', data: setRatiosArr, backgroundColor: '#94a3b8', borderRadius: 4 },
                            { label: 'Act Ratio (%)', data: actRatiosArr, backgroundColor: '#0d9488', borderRadius: 4 }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            if (window.blenderVarChartInst && typeof window.blenderVarChartInst.destroy === 'function') {
                window.blenderVarChartInst.destroy();
            }
            const ctxVarEl = document.getElementById('blenderVarChart');
            if (ctxVarEl) {
                window.blenderVarChartInst = new Chart(ctxVarEl.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Weigh Accuracy (%)', data: accuraciesArr, backgroundColor: 'rgba(99, 102, 241, 0.7)', borderColor: '#4f46e5', borderWidth: 2, borderRadius: 4 }
                        ]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        scales: { y: { min: 95, max: 105 } }
                    }
                });
            }
            
            setTimeout(() => { initResizableColumns(); }, 50);
        }

