        function importPartialCSV(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                const lines = e.target.result.split("\n");
                let importedCount = 0; let importedStockCode = ""; let importedTargetSize = 0; let importedJobNo = "";
                for (let i = 1; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line) continue;
                    const cols = parseCSVRow(line);
                    if (cols.length >= 2 && cols[0] && !isNaN(Number(cols[1])) && Number(cols[1]) > 0) {
                        state.partials.push({ code: cols[0], amount: Number(cols[1]) });
                        importedCount++;
                        if (importedCount === 1) {
                            if (cols.length >= 4) { importedStockCode = cols[2]; importedTargetSize = Number(cols[3]); }
                            if (cols.length >= 5) { importedJobNo = cols[4]; }
                        }
                    }
                }
                if (importedCount > 0) {
                    if (importedStockCode) { state.stockCode = importedStockCode; document.getElementById("stockCode").value = importedStockCode; }
                    if (importedTargetSize > 0) { state.targetSize = importedTargetSize; document.getElementById("targetSize").value = importedTargetSize; }
                    if (importedJobNo) { document.getElementById("prodJobNo").value = importedJobNo; document.getElementById("statJobNo").innerText = importedJobNo; }
                    saveState();
                } else { 
                    alert(getMsg("유효한 잔량 데이터가 없습니다.", "Invalid CSV data.")); 
                }
                event.target.value = "";
            };
            reader.readAsText(file);
        }
