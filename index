        // TB900 블렌더 통계
        function importBlenderCSV(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                const lines = text.split(/\r?\n/);
                
                let headerIdx = -1;
                let headers = [];
                
                for (let i = 0; i < Math.min(15, lines.length); i++) {
                    const cols = parseCSVRow(lines[i]);
                    const cleanCols = cols.map(c => c.replace(/\s+/g, ''));
                    if (cleanCols.includes("SetWght") && cleanCols.includes("ActWght")) {
                        headerIdx = i;
                        headers = cleanCols;
                        break;
                    }
                }
                
                if (headerIdx === -1) {
                    alert("유효한 TB900 블렌더 데이터 형식을 찾을 수 없습니다. (SetWght, ActWght 헤더 필수)");
                    event.target.value = "";
                    return;
                }
                
                const setIdxs = [];
                const actIdxs = [];
                headers.forEach((h, i) => {
                    if (h === "SetWght") setIdxs.push(i);
                    if (h === "ActWght") actIdxs.push(i);
                });
                
                if (setIdxs.length === 0 || actIdxs.length === 0) {
                    alert("TB900 데이터 형식이 올바르지 않습니다.");
                    event.target.value = "";
                    return;
                }

                const compNames = ["Component A", "Component B", "Component C", "Component D", "Component E", "Component F"];
                const numComps = Math.min(setIdxs.length, compNames.length);
                
                const parsedData = {};
                for(let i=0; i<numComps; i++) {
                    parsedData[compNames[i]] = { sets: [], acts: [] };
                }
                
                for (let i = headerIdx + 1; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line) continue;
                    const cols = parseCSVRow(line);
                    
                    if(cols.length <= actIdxs[0]) continue;

                    for(let c=0; c<numComps; c++) {
                        const sVal = Number(cols[setIdxs[c]]);
                        const aVal = Number(cols[actIdxs[c]]);
                        if (!isNaN(sVal) && !isNaN(aVal) && (sVal > 0 || aVal > 0)) { 
                            parsedData[compNames[c]].sets.push(sVal);
                            parsedData[compNames[c]].acts.push(aVal);
                        }
                    }
                }
                
                state.blenderData = parsedData;
                saveState();
                
                setTimeout(() => { renderBlenderView(); }, 50);
            };
            reader.readAsText(file);
            event.target.value = ""; 
        }

        function clearBlenderData() {
            if(confirm("업로드된 TB900 블렌더 분석 데이터를 초기화하시겠습니까?")) {
