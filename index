        // ======= [복구 및 고도화됨: Time Track CSV 업로드 로직] =======
        function importTimeTrackCSV(event) {
            const file = event.target.files[0];
            if (!file) return;

            if (!confirm(getMsg("새 CSV 파일을 업로드하면 기존의 타임 트랙 데이터가 모두 삭제되고 덮어쓰기 됩니다.\n계속하시겠습니까?", "Uploading a new CSV will overwrite all existing Time Track data.\nContinue?"))) {
                event.target.value = ""; 
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                const lines = text.split(/\r?\n/);
                if (lines.length < 2) return;
                
                // BOM 특수문자 및 엑셀 따옴표 완전 제거
                let headers = parseCSVRow(lines[0]).map(h => h.replace(/^\uFEFF/, '').replace(/"/g, '').trim().toLowerCase());
                
                // 유연한 헤더 매칭 (영어/한글 모두 대응)
                let cWorker = headers.findIndex(h => h.includes('worker') || h.includes('작업자') || h.includes('이름') || h.includes('name'));
                let cJob = headers.findIndex(h => h.includes('job') || h.includes('작업지시') || h.includes('wo'));
                let cOp = headers.findIndex(h => h.includes('op') || h.includes('공정') || h.includes('operation'));
                let cStart = headers.findIndex(h => h.includes('start') || h.includes('시작'));
                let cEnd = headers.findIndex(h => h.includes('end') || h.includes('종료') || h.includes('끝'));

                let tMix = headers.findIndex(h => h.includes('mixing task') || h.includes('mixing') || h.includes('믹싱'));
                let tExt = headers.findIndex(h => h.includes('extrusion task') || h.includes('extrusion') || h.includes('extruder') || h.includes('압출'));
                let tGen = headers.findIndex(h => h === 'task' || h.includes('작업') || h.includes('업무'));

                if (cWorker === -1) cWorker = 0;
                if (cJob === -1) cJob = 1;
                if (cOp === -1) cOp = 2;
                if (cStart === -1) cStart = 3;
                if (cEnd === -1) cEnd = 4;

                let count = 0;
                let newTimeTracks = []; 

                for (let i = 1; i < lines.length; i++) {
                    const line = lines[i].trim();
                    if (!line) continue;
                    
                    const cols = parseCSVRow(line).map(c => c.replace(/"/g, '').trim());
                    let startVal = cols[cStart] ? cols[cStart] : "";
                    let endVal = cols[cEnd] ? cols[cEnd] : "";
                    
                    if (startVal) { 
                        if (!endVal) {
                            let sDate = new Date(startVal);
                            if (!isNaN(sDate.getTime())) {
                                let now = new Date();
                                if (sDate.toDateString() === now.toDateString()) {
                                    let h = String(now.getHours()).padStart(2, '0');
                                    let min = String(now.getMinutes()).padStart(2, '0');
                                    endVal = `${startVal.substring(0, 10)} ${h}:${min}`;
                                } else {
                                    endVal = `${startVal.substring(0, 10)} 17:00`;
                                }
                            }
                        }

                        if (endVal) {
                            let taskValue = "-";
                            let tasks = [];
                            
                            if (tMix !== -1 && cols[tMix] && cols[tMix] !== "") tasks.push(cols[tMix]);
                            if (tExt !== -1 && cols[tExt] && cols[tExt] !== "") tasks.push(cols[tExt]);
                            
                            if (tasks.length === 0 && tGen !== -1 && cols[tGen] && cols[tGen] !== "") {
                                tasks.push(cols[tGen]);
                            }

                            if (tasks.length > 0) {
                                taskValue = tasks.join(" / ");
                            }

                            newTimeTracks.push({
                                id: 'tt_' + Date.now() + Math.random().toString(36).substr(2, 5),
                                worker: cols[cWorker] || "-",
                                jobNo: cols[cJob] || "-",
                                operation: cols[cOp] || "-",
                                task: taskValue,
                                startTime: startVal,
                                endTime: endVal
                            });
                            count++;
                        }
                    }
                }
                
                if (count > 0) {
                    state.timeTracks = newTimeTracks;
                    saveState();
                    if (typeof updateTtFilterDropdown === 'function') updateTtFilterDropdown();
                    if (typeof renderTimeTracks === 'function') renderTimeTracks();
                    alert(getMsg(`${count}개의 데이터로 성공적으로 덮어쓰기 되었습니다.\n(종료 시간이 없는 항목은 자동 보정됨)`, `Successfully overwritten with ${count} new time tracks.`));
                } else {
                    alert(getMsg("유효한 데이터를 찾을 수 없습니다. CSV 파일의 '시작 시간' 열에 올바른 날짜 데이터가 있는지 확인하세요.", "Could not find valid time track data. Check CSV format."));
                }
            };
            reader.readAsText(file);
            event.target.value = ""; 
        }

// ======= [신규 추가: 완벽하게 독립적으로 동작하는 드롭다운 연동 로직] =======
        function updateTtFilterDropdown() {
            const typeSelect = document.getElementById("ttFilterType");
            const valSelect = document.getElementById("ttFilterValue");
            if (!typeSelect || !valSelect) return;
            
            const type = typeSelect.value;
         
            // 1. 첫 번째 드롭다운이 '전체 보기'일 때 두 번째 닫기
            if (!type) {
                valSelect.innerHTML = `<option value="">항목 선택...</option>`;
                valSelect.disabled = true;
                valSelect.classList.remove("bg-white");
                valSelect.classList.add("bg-gray-100");
                renderTimeTracks();
                return;
            }

            // 2. 다른 함수 참조 없이 내부에서 기간 필터(1주, 1달 등) 즉시 계산
            let period = typeof ttPeriodDays !== 'undefined' ? ttPeriodDays : 0;
            let baseTracks = state.timeTracks || [];
            
            if (period > 0) {
                const cutoffDate = new Date();
                cutoffDate.setDate(cutoffDate.getDate() - period);
                cutoffDate.setHours(0, 0, 0, 0);

                baseTracks = baseTracks.filter(tt => {
                    const d = new Date(tt.startTime);
                    if (isNaN(d.getTime())) return true;
                    d.setHours(0, 0, 0, 0);
                    return d >= cutoffDate; 
                });
            }

            // 3. 필터링된 데이터에서 항목 추출 (공백 오류 방지)
            const uniqueValues = new Set();
            baseTracks.forEach(tt => {
                let val = tt[type];
                if (val !== undefined && val !== null) {
                    let strVal = String(val).trim(); // 띄어쓰기로 인한 버그 원천 차단
                    if (strVal !== "" && strVal !== "-") {
                        uniqueValues.add(strVal);
                    }
                }
            });

            // 4. 두 번째 드롭다운에 옵션 꽂아넣기
            const sortedValues = Array.from(uniqueValues).sort();
            valSelect.innerHTML = `<option value="">전체 (All)</option>` + sortedValues.map(v => `<option value="${v}">${v}</option>`).join("");
            
            valSelect.disabled = false;
            valSelect.classList.remove("bg-gray-100");
            valSelect.classList.add("bg-white");
            
            // 5. 화면 즉시 갱신
            renderTimeTracks(); 
        }

        // ======= [신규 기능: Time Track 데이터 CSV 내보내기] =======
        function exportTimeTrackCSV() {
            if (!state.timeTracks || state.timeTracks.length === 0) {
                alert(getMsg("내보낼 타임 트랙 데이터가 없습니다.", "No Time Track data to export."));
                return;
            }

            // 엑셀에서 한글이 깨지지 않도록 BOM(\uFEFF) 추가
            let csvContent = "data:text/csv;charset=utf-8,\uFEFF";
            csvContent += "Worker,JobNo,Operation,Task,StartTime,EndTime\n";
            
            // 현재 시스템에 로드된 모든 데이터를 순회하며 CSV 문자열로 변환
            state.timeTracks.forEach(tt => {
                let row = [
                    `"${(tt.worker || '-').trim()}"`,
                    `"${(tt.jobNo || '-').trim()}"`,
                    `"${(tt.operation || '-').trim()}"`,
                    `"${(tt.task || '-').trim()}"`,
                    `"${(tt.startTime || '').trim()}"`,
                    `"${(tt.endTime || '').trim()}"`
                ];
                csvContent += row.join(",") + "\n";
            });

            // 파일 다운로드 트리거
            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `TimeTrack_Data_${new Date().toISOString().slice(0, 10)}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }


        function renderTimeTracks() {
            const container = document.getElementById("view-workload"); 
            if (!container || container.classList.contains("hidden")) return;

            const emptyState = document.getElementById("timeTrackEmptyState");
            const summaryArea = document.getElementById("timeTrackSummaryArea");
            const rawBody = document.getElementById("ttRawBody");
            const timelineArea = document.getElementById("ttTimelineArea");

            if (!state.timeTracks || state.timeTracks.length === 0) {
                emptyState.classList.remove("hidden");
                summaryArea.classList.add("hidden");
                rawBody.innerHTML = "";
                if (timelineArea) timelineArea.classList.add("hidden");
                return;
            }

            emptyState.classList.add("hidden");
            summaryArea.classList.remove("hidden");

            let baseTracks = state.timeTracks;
            if (typeof ttPeriodDays !== 'undefined' && ttPeriodDays > 0) {
                const cutoffDate = new Date();
                cutoffDate.setDate(cutoffDate.getDate() - ttPeriodDays);
                cutoffDate.setHours(0, 0, 0, 0);

                baseTracks = baseTracks.filter(tt => {
                    const d = new Date(tt.startTime);
                    if (isNaN(d.getTime())) return true;
                    d.setHours(0, 0, 0, 0);
                    return d >= cutoffDate; 
                });
            }

            const filterType = document.getElementById("ttFilterType")?.value;
            const filterVal = document.getElementById("ttFilterValue")?.value;
            
            const filteredTimeTracks = baseTracks.filter(tt => {
                if (!filterType || !filterVal) return true;
                
                // [수정됨] 비교하기 전에 원본 데이터의 공백을 제거하여 완벽하게 매칭시킵니다.
                let val = tt[filterType];
                if (val && typeof val === 'string') val = val.trim();
                
                return val === filterVal;
            });

            // 1. 원본 데이터 테이블 렌더링
            let rawHtml = "";
            filteredTimeTracks.forEach(tt => {
                // [변경] 원본 작업이 같은 날 시작하고 끝났는지 판별
                const sDate = new Date(tt.startTime);
                const eDate = new Date(tt.endTime);
                const isOrigSame = (sDate.toDateString() === eDate.toDateString());
                const duration = formatMins(calcWorkingMins(tt.startTime, tt.endTime, isOrigSame));
                
                rawHtml += `
                    <tr class="hover:bg-gray-50 border-b border-gray-100">
                        <td class="px-3 py-2 text-gray-700 font-bold">${tt.worker}</td>
                        <td class="px-3 py-2 text-gray-700 font-mono">${tt.jobNo}</td>
                        <td class="px-3 py-2 text-gray-700">${tt.operation}</td>
                        <td class="px-3 py-2 text-indigo-700 font-bold bg-indigo-50">${tt.task || "-"}</td>
                        <td class="px-3 py-2 text-gray-500 whitespace-nowrap">${tt.startTime}</td>
                        <td class="px-3 py-2 text-gray-500 whitespace-nowrap">${tt.endTime}</td>
                        <td class="px-3 py-2 text-green-700 font-bold">${duration}</td>
                    </tr>
                `;
            });
            rawBody.innerHTML = rawHtml || `<tr><td colspan="7" class="text-center py-4 text-gray-400">해당 기간 및 필터 조건에 맞는 데이터가 없습니다.</td></tr>`;

            // 2. 요약 테이블
            const gbWorker = document.getElementById("gb-worker")?.checked;
            const gbJob = document.getElementById("gb-job")?.checked;
            const gbOp = document.getElementById("gb-op")?.checked;
            const gbTask = document.getElementById("gb-task")?.checked;

            const thead = document.getElementById("ttSummaryHead");
            const tbody = document.getElementById("ttSummaryBody");
            
            const getTh = (label, colId, customClasses = "") => {
                let icon = ttSortCol === colId ? (ttSortAsc ? " ▲" : " ▼") : "";
                return `<th class="px-4 py-3 font-bold cursor-pointer hover:bg-green-100 transition select-none ${customClasses}" onclick="sortTimeTrackSummary('${colId}')">${label}<span class="text-[10px] text-gray-500">${icon}</span></th>`;
            };

            let theadHtml = "<tr>";
            if (gbWorker) theadHtml += getTh("Worker", "worker", "text-gray-700 border-r border-green-100");
            if (gbJob)    theadHtml += getTh("Job#", "job", "text-gray-700 border-r border-green-100");
            if (gbOp)     theadHtml += getTh("Operation", "op", "text-gray-700 border-r border-green-100");
            if (gbTask)   theadHtml += getTh("Task", "task", "text-indigo-700 border-r border-green-100");
            theadHtml += getTh("Avg Time", "avgTime", "text-gray-700 text-right bg-green-100");
            theadHtml += getTh("Count", "count", "text-gray-700 text-center bg-green-100");
            theadHtml += "</tr>";
            thead.innerHTML = theadHtml;

            const groups = {};
            filteredTimeTracks.forEach(tt => {
                const parts = {
                    worker: gbWorker ? (tt.worker || "-").trim() : "",
                    job: gbJob ? (tt.jobNo || "-").trim() : "",
                    op: gbOp ? (tt.operation || "-").trim() : "",
                    task: gbTask ? (tt.task || "-").trim() : ""
                };
                
                const keyPartsArr = [];
                if (gbWorker) keyPartsArr.push(parts.worker);
                if (gbJob)    keyPartsArr.push(parts.job);
                if (gbOp)     keyPartsArr.push(parts.op);
                if (gbTask)   keyPartsArr.push(parts.task);
                
                const key = keyPartsArr.length > 0 ? keyPartsArr.join("|||") : "Total All";
                if (!groups[key]) {
                    groups[key] = { minSum: 0, count: 0, parts: parts, isTotal: keyPartsArr.length === 0 };
                }
                
                const sDate = new Date(tt.startTime);
                const eDate = new Date(tt.endTime);
                const isOrigSame = (sDate.toDateString() === eDate.toDateString());
                
                const m = calcWorkingMins(tt.startTime, tt.endTime, isOrigSame);
                if (m !== null && !isNaN(m)) {
                    groups[key].minSum += m;
                    groups[key].count++;
                }
            });

            const groupArray = Object.values(groups).filter(g => g.count > 0);
            groupArray.forEach(g => { g.avgMin = g.minSum / g.count; });

            if (ttSortCol) {
                groupArray.sort((a, b) => {
                    let valA, valB;
                    if (ttSortCol === 'avgTime') { valA = a.avgMin; valB = b.avgMin; } 
                    else if (ttSortCol === 'count') { valA = a.count; valB = b.count; } 
                    else { valA = a.parts[ttSortCol] || ""; valB = b.parts[ttSortCol] || ""; }

                    if (valA < valB) return ttSortAsc ? -1 : 1;
                    if (valA > valB) return ttSortAsc ? 1 : -1;
                    return 0;
                });
            }

            let tbodyHtml = "";
            groupArray.forEach(g => {
                tbodyHtml += `<tr class="hover:bg-green-50 transition border-b border-gray-100">`;
                if (!g.isTotal) {
                    if (gbWorker) tbodyHtml += `<td class="px-4 py-3 text-gray-800 font-medium border-r border-gray-100">${g.parts.worker}</td>`;
                    if (gbJob)    tbodyHtml += `<td class="px-4 py-3 text-gray-800 font-medium border-r border-gray-100">${g.parts.job}</td>`;
                    if (gbOp)     tbodyHtml += `<td class="px-4 py-3 text-gray-800 font-medium border-r border-gray-100">${g.parts.op}</td>`;
                    if (gbTask)   tbodyHtml += `<td class="px-4 py-3 text-gray-800 font-medium border-r border-gray-100">${g.parts.task}</td>`;
                } else {
                    tbodyHtml += `<td class="px-4 py-3 text-gray-800 font-black border-r border-gray-100" colspan="100%">Total All</td>`;
                }
                
                tbodyHtml += `<td class="px-4 py-3 text-right font-bold text-green-700 bg-green-50 bg-opacity-50">${formatMins(g.avgMin)}</td>`;
                tbodyHtml += `<td class="px-4 py-3 text-center font-mono text-gray-600 bg-green-50 bg-opacity-50">${g.count}</td>`;
                tbodyHtml += `</tr>`;
            });
            tbody.innerHTML = tbodyHtml;
            
            if (timelineArea) timelineArea.classList.remove("hidden");

            const ctxTimeline = document.getElementById("ttTimelineChart");
            if (ttTimelineChartInst) ttTimelineChartInst.destroy();

            const dateInput = document.getElementById("timelineDateSelect");
            const selectedDate = dateInput ? dateInput.value : "";
            
            const workerSelect = document.getElementById("timelineWorkerSelect");
            const selectedWorker = workerSelect ? workerSelect.value : "";

            if (workerSelect) {
                const wSet = new Set();
                baseTracks.forEach(t => { if(t.worker && t.worker !== "-") wSet.add(t.worker.trim()); });
                const sortedW = Array.from(wSet).sort();
                
                const curStr = Array.from(workerSelect.options).map(o=>o.value).join(",");
                const newStr = ["", ...sortedW].join(",");
                if(curStr !== newStr) {
                    workerSelect.innerHTML = '<option value="">모든 작업자</option>';
                    sortedW.forEach(w => {
                        const opt = document.createElement("option");
                        opt.value = w; opt.text = w;
                        if(w === selectedWorker) opt.selected = true;
                        workerSelect.appendChild(opt);
                    });
                }

                const groupCbContainer = document.getElementById("groupWorkerCheckboxes");
                if (groupCbContainer) {
                    const currentCbs = Array.from(groupCbContainer.querySelectorAll('.group-worker-cb')).map(cb => cb.value).join(",");
                    const sortedWStr = sortedW.join(",");
                    
                    if (currentCbs !== sortedWStr) {
                        if (sortedW.length === 0) {
                            groupCbContainer.innerHTML = '<span class="text-gray-400 text-xs py-1">저장된 작업자 데이터가 없습니다. 아래에 직접 입력하세요.</span>';
                        } else {
                            groupCbContainer.innerHTML = sortedW.map(w => `
                                <label class="flex items-center space-x-1 bg-green-50 px-2 py-1 rounded border border-green-200 cursor-pointer hover:bg-green-100 transition">
                                    <input type="checkbox" value="${w}" class="group-worker-cb text-green-600 focus:ring-green-50 rounded cursor-pointer">
                                    <span class="text-xs font-bold text-green-900">${w}</span>
                                </label>
                            `).join("");
                        }
                    }
                }
            }

            const tempTimelineData = [];
            const rawIntervalsMap = {}; 
            const availableDates = new Set();

            filteredTimeTracks.forEach(tt => {
                let currentStart = new Date(tt.startTime);
                const finalEnd = new Date(tt.endTime);
                
                if (isNaN(currentStart.getTime()) || isNaN(finalEnd.getTime()) || currentStart > finalEnd) return;

                const workerName = (tt.worker || "-").trim();
                // [변경] 당일치기 작업인지 기록
                const isOriginalSameDay = (currentStart.toDateString() === finalEnd.toDateString());

                while (currentStart < finalEnd) {
                    let isSameDay = (currentStart.toDateString() === finalEnd.toDateString());
                    let endOfWorkDay = new Date(currentStart.getFullYear(), currentStart.getMonth(), currentStart.getDate(), 17, 0, 0, 0);
                    
                    let currentEnd;
                    if (isSameDay) {
                        currentEnd = finalEnd;
                    } else {
                        currentEnd = new Date(Math.min(finalEnd.getTime(), endOfWorkDay.getTime()));
                    }

                    // [변경] calcWorkingMins에 플래그 전달
                    if (currentStart < currentEnd && calcWorkingMins(currentStart, currentEnd, isOriginalSameDay) > 0) {
                        const y = currentStart.getFullYear();
                        const m = String(currentStart.getMonth() + 1).padStart(2, '0');
                        const d = String(currentStart.getDate()).padStart(2, '0');
                        const dateStr = `${y}-${m}-${d}`;
                        
                        availableDates.add(dateStr);

                        let passDate = (!selectedDate || dateStr === selectedDate);
                        let passWorker = (!selectedWorker || workerName === selectedWorker);

                        if (passDate && passWorker) {
                            const rawYLabel = selectedDate ? workerName : `${workerName} (${dateStr})`;
                            
                            if (!rawIntervalsMap[rawYLabel]) rawIntervalsMap[rawYLabel] = [];
                            rawIntervalsMap[rawYLabel].push({ 
                                start: new Date(currentStart), 
                                end: new Date(currentEnd),
                                removeBounds: isOriginalSameDay // 플래그 버퍼에 저장
                            });

                            let startDec = currentStart.getHours() + currentStart.getMinutes() / 60;
                            let endDec = currentEnd.getHours() + currentEnd.getMinutes() / 60;
                            
                            startDec = Math.max(startDec, 8);
                            endDec = Math.min(endDec, 21);

                            tempTimelineData.push({
                                rawY: rawYLabel,
                                x: [startDec, endDec],
                                task: tt.task,
                                op: tt.operation
                            });
                        }
                    }

                    if (isSameDay) {
                        break; 
                    } else {
                        currentStart = new Date(currentStart.getFullYear(), currentStart.getMonth(), currentStart.getDate() + 1, 9, 0, 0, 0);
                    }
                }
            });

            // [변경] 병합 시 바운더리 제거 옵션(removeBounds)도 같이 병합
            const dailyMinsMap = {};
            for (const label in rawIntervalsMap) {
                let intervals = rawIntervalsMap[label].sort((a, b) => a.start.getTime() - b.start.getTime());
                let merged = [];
                
                if (intervals.length > 0) {
                    merged.push({ 
                        start: new Date(intervals[0].start), 
                        end: new Date(intervals[0].end),
                        removeBounds: intervals[0].removeBounds
                    });
                    for (let i = 1; i < intervals.length; i++) {
                        let lastMerged = merged[merged.length - 1];
                        let current = intervals[i];
                        
                        if (current.start.getTime() <= lastMerged.end.getTime()) {
                            lastMerged.end = new Date(Math.max(lastMerged.end.getTime(), current.end.getTime()));
                            // 둘 중 하나라도 바운더리 해제가 있으면 병합된 구간도 해제
                            lastMerged.removeBounds = lastMerged.removeBounds || current.removeBounds;
                        } else {
                            merged.push({ 
                                start: new Date(current.start), 
                                end: new Date(current.end),
                                removeBounds: current.removeBounds
                            });
                        }
                    }
                }
                
                let totalMins = 0;
                merged.forEach(iv => {
                    totalMins += (calcWorkingMins(iv.start, iv.end, iv.removeBounds) || 0);
                });
                
                dailyMinsMap[label] = totalMins;
            }

            const finalTimelineData = [];
            const yLabelsSet = new Set();
            
            tempTimelineData.forEach(d => {
                const totalMins = dailyMinsMap[d.rawY] || 0;
                const pct = Math.round((totalMins / 420) * 100); 
                
                const utilText = getMsg("가동률", "Util"); 
                const finalYLabel = `${d.rawY} [${utilText}: ${pct}%]`;
                yLabelsSet.add(finalYLabel);
                
                finalTimelineData.push({
                    y: finalYLabel,
                    x: d.x,
                    task: d.task,
                    op: d.op
                });
            });

            if (dateInput && availableDates.size > 0) {
                const sortedDates = Array.from(availableDates).sort();
                dateInput.min = sortedDates[0];
                dateInput.max = sortedDates[sortedDates.length - 1];
            }

            const yLabels = Array.from(yLabelsSet).sort();

            if (ctxTimeline && finalTimelineData.length > 0) {
                const workingWindowPlugin = {
                    id: 'workingWindowBackground',
                    beforeDraw: (chart) => {
                        const { ctx, chartArea: { top, bottom }, scales: { x } } = chart;
                        if (!x) return;

                        const startPx = x.getPixelForValue(9);
                        const endPx = x.getPixelForValue(17);
                        
                        ctx.save();
                        ctx.fillStyle = 'rgba(59, 130, 246, 0.1)'; 
                        ctx.fillRect(startPx, top, endPx - startPx, bottom - top);
                        
                        const lunchStartPx = x.getPixelForValue(12);
                        const lunchEndPx = x.getPixelForValue(13);
                        ctx.fillStyle = 'rgba(229, 231, 235, 0.5)'; 
                        ctx.fillRect(lunchStartPx, top, lunchEndPx - lunchStartPx, bottom - top);
                        
                        ctx.restore();
                    }
                };

                ttTimelineChartInst = new Chart(ctxTimeline.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: yLabels,
                        datasets: [{
                            label: getMsg("작업 수행 시간", "Task Duration"),
                            data: finalTimelineData,
                            backgroundColor: 'rgba(16, 185, 129, 0.7)',
                            borderColor: 'rgba(4, 120, 87, 1)',
                            borderWidth: 1,
                            borderRadius: 4,
                            barPercentage: 0.6
                        }]
                    },
                    options: {
                        indexAxis: 'y', 
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: {
                                type: 'linear',
                                min: 8, 
                                max: 21, 
                                beginAtZero: false,
                                title: { display: true, text: 'Time of Day (시)' },
                                ticks: {
                                    stepSize: 1,
                                    callback: function(value) {
                                        const h = Math.floor(value);
                                        const m = Math.round((value - h) * 60);
                                        return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
                                    }
                                }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const raw = context.raw;
                                        const startH = Math.floor(raw.x[0]);
                                        const startM = Math.round((raw.x[0] - startH) * 60);
                                        const endH = Math.floor(raw.x[1]);
                                        const endM = Math.round((raw.x[1] - endH) * 60);
                                        const sTime = `${startH.toString().padStart(2,'0')}:${startM.toString().padStart(2,'0')}`;
                                        const eTime = `${endH.toString().padStart(2,'0')}:${endM.toString().padStart(2,'0')}`;
                                        return `${raw.task || raw.op}: ${sTime} ~ ${eTime}`;
                                    }
                                }
                            }
                        }
                    },
                    plugins: [workingWindowPlugin]
                });
            } else if (timelineArea) {
                timelineArea.classList.add("hidden"); 
            }
            
            setTimeout(() => { initResizableColumns(); }, 50);
        }

        // ==========================================
        // 생산 및 배치 생성 로직
        // ==========================================
        function getNextSequence(date, type) {
            const key = `${date}-${type}`;
            state.counters[key] = (state.counters[key] || 0) + 1;
            return `${date}-${type}${state.counters[key]}`;
        }
        function resetDailyCounter() {
            const date = document.getElementById("prodDate").value;
            if (!date) return;
            if (confirm(getMsg(`선택한 날짜(${date})의 배치 번호 카운터를 초기화하시겠습니까?`, `Reset batch counters for ${date}?`))) {
                delete state.counters[`${date}-B`];
                delete state.counters[`${date}-H`];
                saveState();
                alert(getMsg("카운터가 성공적으로 초기화되었습니다.", "Counter reset successfully."));
            }
        }
        function unlockGenerate() {
            document.getElementById("generateBtn").disabled = false;
            document.getElementById("generateBtn").classList.remove("opacity-50", "cursor-not-allowed");
            document.getElementById("unlockBtn").classList.add("hidden");
        }
        function addManualPartial() {
            const code = prompt(getMsg("수동 이월 잔량 코드를 입력하세요:", "Enter manual partial batch code:"));
            if (!code) return;
            const amount = Number(prompt(getMsg("수동 이월 잔량(Kg)을 입력하세요:", "Enter manual partial batch amount (Kg):")));
            if (!amount || amount <= 0) return;
            state.partials.push({ code: code, amount: amount });
            saveState();
        }
        function removePartial(index) {
            state.partials.splice(index, 1);
            saveState();
        }

        function generateBatches() {
            const date = document.getElementById("prodDate").value;
            let dailyProd = Number(document.getElementById("dailyProd").value);
            const targetSize = Number(document.getElementById("targetSize").value);
            const stockCode = document.getElementById("stockCode").value;
            const jobNo = document.getElementById("prodJobNo").value.trim(); 
            const plannedProd = Number(document.getElementById("plannedProd").value);
            const batchMode = document.querySelector('input[name="batchMode"]:checked').value;

            if (!date || !targetSize || targetSize <= 0 || dailyProd <= 0) {
                alert(getMsg("날짜, 패킹 기준 양, 당일 생산량을 올바르게 입력해주세요.", "Please enter valid Date, Target Size, and Daily Production."));
                return;
            }

            const snapshotPartials = JSON.parse(JSON.stringify(state.partials));
            const snapshotCounters = JSON.parse(JSON.stringify(state.counters));

            state.stockCode = stockCode;
            state.targetSize = targetSize;
            state.actualProd += dailyProd;

            const record = {
                timestamp: new Date().toLocaleString(),
                date: date, stockCode: stockCode, jobNo: jobNo,
                dailyProdInput: dailyProd, batches: [], newPartials: [],
                addedToInventory: false, snapshotPartials: snapshotPartials, snapshotCounters: snapshotCounters,
            };

            let totalPartials = state.partials.reduce((sum, p) => sum + p.amount, 0);
            let totalAvailable = totalPartials + dailyProd;

            if (batchMode === 'grouped') {
                let sharedBCode = null;
                for (let i = 0; i < state.history.length; i++) {
                    if (state.history[i].jobNo === jobNo && state.history[i].batches && state.history[i].batches.length > 0) {
                        sharedBCode = state.history[i].batches[0].code; 
                        break;
                    }
                }
                let currentBCode = sharedBCode || getNextSequence(date, "B");
                let breakdown = [];
                let isPureNew = state.partials.length === 0;
                
                while (state.partials.length > 0) {
                    let p = state.partials.shift();
                    breakdown.push({ code: p.code, amount: p.amount });
                }
                if (!isPureNew && dailyProd > 0) {
                    breakdown.push({ code: getNextSequence(date, "H"), amount: dailyProd });
                }
                
                const numBags = Math.floor(totalAvailable / targetSize);
                const leftover = Math.round((totalAvailable % targetSize) * 1000) / 1000;

                record.batches.push({ 
                    id: 'b_' + Date.now() + Math.random().toString(36).substr(2, 5),
                    code: currentBCode, amount: totalAvailable, isPureNew: isPureNew, breakdown: breakdown, 
                    bags: numBags, targetSize: targetSize, leftoverAmount: leftover 
                });
                
                dailyProd = 0; 
            } 
            else {
                while (totalAvailable >= targetSize) {
                    let remainingToFill = targetSize;
                    let breakdown = [];
                    let isPureNew = true;

                    while (remainingToFill > 0 && state.partials.length > 0) {
                        isPureNew = false;
                        let p = state.partials[0];
                        let usedAmount = Math.min(p.amount, remainingToFill);
                        
                        breakdown.push({ code: p.code, amount: usedAmount });
                        remainingToFill -= usedAmount;
                        p.amount -= usedAmount;
                        if (p.amount <= 0) state.partials.shift();
                    }

                    if (remainingToFill > 0) {
                        if (!isPureNew) {
                            breakdown.push({ code: getNextSequence(date, "H"), amount: remainingToFill });
                        }
                        dailyProd -= remainingToFill;
                    }

                    totalAvailable -= targetSize;

                    record.batches.push({ 
                        id: 'b_' + Date.now() + Math.random().toString(36).substr(2, 5),
                        code: getNextSequence(date, "B"), amount: targetSize, isPureNew: isPureNew, breakdown: breakdown, 
                        bags: 1, targetSize: targetSize, leftoverAmount: 0 
                    });
                }
            }

            if (dailyProd > 0) {
                const remainderHCode = getNextSequence(date, "H");
                const remainderObj = { code: remainderHCode, amount: dailyProd };
                record.newPartials.push(remainderObj);
                state.partials.push(remainderObj);
            }

            const isJobClosing = plannedProd > 0 && state.actualProd >= plannedProd;

            if (isJobClosing && state.partials.length > 0) {
                const totalLeftover = state.partials.reduce((sum, p) => sum + p.amount, 0);
                if (confirm(getMsg(
                    `목표 생산량 도달!\n현재 ${totalLeftover}Kg의 잔량이 남았습니다.\n\n[확인]을 누르시면 온전한 마감용 'B 시리즈' 배치로 변환합니다.\n[취소]를 누르시면 'H 시리즈 잔량'으로 유지합니다.`,
                    `Target production reached.\nThere is ${totalLeftover}Kg partial batch left.\n\nConvert this into a final 'B-Series' batch? (Cancel to keep as 'H-Series')`
                ))) {
                    let leftoverBreakdown = [];
                    let isPureNew = false;
                    if (state.partials.length === 1 && record.newPartials.length === 1 && state.partials[0].code === record.newPartials[0].code) {
                        isPureNew = true;
                    } else {
                        state.partials.forEach((p) => leftoverBreakdown.push({ code: p.code, amount: p.amount }));
                    }

                    let finalBCode = batchMode === 'grouped' ? (sharedBCode || getNextSequence(date, "B")) : getNextSequence(date, "B");
                    let existingFinal = record.batches.find(b => b.code === finalBCode);

                    if (batchMode === 'grouped' && existingFinal) {
                        existingFinal.amount += totalLeftover;
                        existingFinal.bags = Math.floor(existingFinal.amount / targetSize);
                        existingFinal.leftoverAmount = Math.round((existingFinal.amount % targetSize) * 1000) / 1000;
                        existingFinal.isPureNew = existingFinal.isPureNew && isPureNew;
                        leftoverBreakdown.forEach(bd => {
                            let exBd = existingFinal.breakdown.find(x => x.code === bd.code);
                            if (exBd) exBd.amount += bd.amount;
                            else existingFinal.breakdown.push(bd);
                        });
                    } else {
                        const numBags = Math.floor(totalLeftover / targetSize);
                        const leftover = Math.round((totalLeftover % targetSize) * 1000) / 1000;
                        record.batches.push({ 
                            id: 'b_' + Date.now() + Math.random().toString(36).substr(2, 5),
                            code: finalBCode, amount: totalLeftover, isPureNew: isPureNew, 
                            breakdown: leftoverBreakdown, bags: numBags, targetSize: targetSize, leftoverAmount: leftover 
                        });
                    }
                    
                    state.partials = [];
                    record.newPartials = [];
                }
            }

            state.history.unshift(record);
            document.getElementById("dailyProd").value = "";
            saveState();

            if (isJobClosing) {
                document.getElementById("generateBtn").disabled = true;
                document.getElementById("generateBtn").classList.add("opacity-50", "cursor-not-allowed");
                document.getElementById("unlockBtn").classList.remove("hidden"); 

                if (state.partials.length > 0) {
                    if (confirm(getMsg("마감되지 않은 잔량이 있습니다.\n다음 작업을 위해 이월 잔량 CSV를 내보내시겠습니까?", "Export leftover CSV for the next job?"))) {
                        exportLeftoverCSV();
                    }
                }

                setTimeout(() => {
                    if (confirm(getMsg("시스템을 초기화하고 새 Job을 준비하시겠습니까?", "Reset system for new job?"))) {
                        state.stockCode = ""; state.targetSize = 0; state.plannedProd = 0; state.actualProd = 0; state.partials = [];
                        ["stockCode", "prodJobNo", "targetSize", "plannedProd", "dailyProd"].forEach(id => document.getElementById(id).value = "");
                        document.getElementById("generateBtn").disabled = false;
                        document.getElementById("generateBtn").classList.remove("opacity-50", "cursor-not-allowed");
                        document.getElementById("unlockBtn").classList.add("hidden");
                        saveState();
                    }
                }, 100);
            }
        }

        function undoLast() {
            if (state.history.length === 0) return;
            if (confirm(getMsg("직전 생성 기록을 삭제하고 이전 상태로 되돌리시겠습니까?", "Undo last batch generation?"))) {
                const last = state.history[0]; 
                
                if (last.addedToInventory) {
                    const batchIds = last.batches.map(b => b.id);
                    const batchCodes = last.batches.map((b) => b.code); 
                    
                    const relatedInventory = state.inventory.filter((inv) => inv.historyBatchId ? batchIds.includes(inv.historyBatchId) : batchCodes.includes(inv.batchCode));
                    const isUsed = relatedInventory.some((inv) => inv.currentQty !== inv.initialQty);
                    
                    if (isUsed) { 
                        alert(getMsg("이미 자재가 출고(사용)된 배치가 포함되어 실행 취소할 수 없습니다.", "Cannot undo because batches are partially used.")); 
                        return; 
                    }
                    
                    state.inventory = state.inventory.filter((inv) => inv.historyBatchId ? !batchIds.includes(inv.historyBatchId) : !batchCodes.includes(inv.batchCode));
                    state.transactions = state.transactions.filter((t) => t.historyBatchId ? !batchIds.includes(t.historyBatchId) : !(t.type === "IN" && batchCodes.includes(t.batchCode)));
                }

                state.history.shift();
                
                state.actualProd -= last.dailyProdInput;
                if (state.actualProd < 0) state.actualProd = 0; 

                state.partials = last.snapshotPartials;
                state.counters = last.snapshotCounters;

                const plannedProd = Number(document.getElementById("plannedProd").value) || state.plannedProd;
                if (plannedProd > 0 && state.actualProd < plannedProd) {
                    document.getElementById("generateBtn").disabled = false; 
                    document.getElementById("generateBtn").classList.remove("opacity-50", "cursor-not-allowed");
                    document.getElementById("unlockBtn").classList.add("hidden");
                }
                saveState();
            }
        }

        function deleteHistoryItem(index) {
            const rec = state.history[index];
            if (rec.addedToInventory) { 
                alert(getMsg("이미 창고에 입고 처리된 기록은 바로 삭제할 수 없습니다. '입고 취소'를 먼저 진행해주세요.", "Cannot delete record already added to inventory. Cancel inbound first.")); 
                return; 
            }
            if (confirm(getMsg("이 생산 기록을 완전히 삭제하시겠습니까?", "Delete this record entirely?"))) {
                state.actualProd -= rec.dailyProdInput;
                if (state.actualProd < 0) state.actualProd = 0; 
                state.history.splice(index, 1);
                saveState(); 
            }
        }

        function enableEdit(index) { editingIndex = index; updateUI(); }
        function cancelEdit() { editingIndex = -1; updateUI(); }

        function saveEdit(index) {
            const rec = state.history[index];
            const newJob = document.getElementById(`editJob_${index}`).value;
            const newProd = Number(document.getElementById(`editProd_${index}`).value);
            
            const diff = newProd - rec.dailyProdInput;
            
            if (diff !== 0 && rec.addedToInventory) {
                const batchIds = rec.batches.map(b => b.id);
                const isUsed = state.inventory.some(inv => batchIds.includes(inv.historyBatchId) && inv.currentQty !== inv.initialQty);
                if (isUsed) {
                    alert(getMsg("이미 자재가 사용(출고)된 배치는 생산 수량을 변경할 수 없습니다.", "Cannot change quantity of partially used batches."));
                    return;
                }
            }

            state.actualProd += diff;
            if (state.actualProd < 0) state.actualProd = 0;
            
            rec.jobNo = newJob; 
            rec.dailyProdInput = newProd;

            if (diff !== 0) {
                let isGrouped = false;
                if (rec.batches.length === 1 && rec.newPartials.length === 0) isGrouped = true; 
                else if (rec.batches.length === 1 && rec.batches[0].amount > (rec.batches[0].targetSize || state.targetSize)) isGrouped = true;

                let totalPartials = rec.snapshotPartials.reduce((sum, p) => sum + p.amount, 0);
                let totalAvailable = totalPartials + newProd;
                let dailyProd = newProd;
                
                let targetSize = rec.batches.length > 0 && rec.batches[0].targetSize > 0 ? rec.batches[0].targetSize : state.targetSize;
                if (!targetSize || targetSize <= 0) targetSize = 1; 
                
                let oldBCodes = rec.batches.map(b => ({id: b.id, code: b.code}));
                let oldHCodes = rec.newPartials.map(p => p.code);
                
                let newBatches = [];
                let newNewPartials = [];
                let tempPartials = JSON.parse(JSON.stringify(rec.snapshotPartials));

                if (isGrouped) {
                    let sharedBCode = oldBCodes.length > 0 ? oldBCodes[0].code : getNextSequence(rec.date, "B");
                    let bId = oldBCodes.length > 0 ? oldBCodes[0].id : 'b_' + Date.now() + Math.random().toString(36).substr(2, 5);
                    
                    let breakdown = [];
                    let isPureNew = tempPartials.length === 0;
                    while (tempPartials.length > 0) {
                        let p = tempPartials.shift();
                        breakdown.push({ code: p.code, amount: p.amount });
                    }
                    if (!isPureNew && dailyProd > 0) {
                        let hCode = oldHCodes.length > 0 ? oldHCodes[0] : getNextSequence(rec.date, "H");
                        breakdown.push({ code: hCode, amount: dailyProd });
                    }
                    
                    const numBags = Math.floor(totalAvailable / targetSize);
                    const leftover = Math.round((totalAvailable % targetSize) * 1000) / 1000;

                    newBatches.push({ 
                        id: bId, code: sharedBCode, amount: totalAvailable, 
                        isPureNew: isPureNew, breakdown: breakdown, 
                        bags: numBags, targetSize: targetSize, leftoverAmount: leftover 
                    });
                    dailyProd = 0;
                } else {
                    let bIdx = 0;
                    while (totalAvailable >= targetSize) {
                        let remainingToFill = targetSize;
                        let breakdown = [];
                        let isPureNew = true;
                        while (remainingToFill > 0 && tempPartials.length > 0) {
                            isPureNew = false;
                            let p = tempPartials[0];
                            let usedAmount = Math.min(p.amount, remainingToFill);
                            breakdown.push({ code: p.code, amount: usedAmount });
                            remainingToFill -= usedAmount;
                            p.amount -= usedAmount;
                            if (p.amount <= 0) tempPartials.shift();
                        }
                        if (remainingToFill > 0) {
                            if (!isPureNew) {
                                let hCode = getNextSequence(rec.date, "H");
                                breakdown.push({ code: hCode, amount: remainingToFill });
                            }
                            dailyProd -= remainingToFill;
                        }
                        totalAvailable -= targetSize;

                        let bCode = bIdx < oldBCodes.length ? oldBCodes[bIdx].code : getNextSequence(rec.date, "B");
                        let bId = bIdx < oldBCodes.length ? oldBCodes[bIdx].id : 'b_' + Date.now() + Math.random().toString(36).substr(2, 5);
                        
                        newBatches.push({ 
                            id: bId, code: bCode, amount: targetSize, 
                            isPureNew: isPureNew, breakdown: breakdown, 
                            bags: 1, targetSize: targetSize, leftoverAmount: 0 
                        });
                        bIdx++;
                    }
                }

                if (dailyProd > 0) {
                    let hCode = oldHCodes.length > 0 ? oldHCodes[0] : getNextSequence(rec.date, "H");
                    newNewPartials.push({ code: hCode, amount: dailyProd });
                }

                if (rec.addedToInventory) {
                    const oldBatchIds = rec.batches.map(b => b.id);
                    state.inventory = state.inventory.filter(inv => !oldBatchIds.includes(inv.historyBatchId));
                    state.transactions = state.transactions.filter(t => !oldBatchIds.includes(t.historyBatchId) || t.type !== "IN");

                    newBatches.forEach(b => {
                        state.inventory.push({
                            id: 'inv_' + Date.now() + Math.random().toString(36).substr(2, 5),
                            historyBatchId: b.id, inboundDate: rec.date, stockCode: rec.stockCode,
                            batchCode: b.code, initialQty: b.amount, currentQty: b.amount, status: "Available" 
                        });
                        state.transactions.unshift({
                            id: 'trx_' + Date.now() + Math.random().toString(36).substr(2, 5),
                            historyBatchId: b.id, timestamp: new Date().toLocaleString(), type: "IN", 
                            stockCode: rec.stockCode, batchCode: b.code, jobNo: rec.jobNo, amount: b.amount,
                            remarks: "Edited batch inbound" 
                        });
                    });
                }

                rec.batches = newBatches;
                rec.newPartials = newNewPartials;
                if (index === 0) state.partials = JSON.parse(JSON.stringify(rec.newPartials));
            } 
            
            if (rec.batches && rec.batches.length > 0) {
                rec.batches.forEach((b, bIndex) => {
                    const el = document.getElementById(`editBCode_${index}_${bIndex}`);
                    if (el) {
                        const newCode = el.value.trim();
                        if (newCode && newCode !== b.code) {
                            b.code = newCode;
                            state.inventory.forEach(inv => { if (inv.historyBatchId === b.id) inv.batchCode = newCode; });
                            state.transactions.forEach(t => { if (t.historyBatchId === b.id) t.batchCode = newCode; });
                        }
                    }
                });
            }
            if (rec.newPartials && rec.newPartials.length > 0) {
                rec.newPartials.forEach((p, pIndex) => {
                    const el = document.getElementById(`editPCode_${index}_${pIndex}`);
                    if (el) p.code = el.value.trim();
                });
            }
            
            editingIndex = -1; 
            saveState(); 
        }

        function addAllToInventory() {
            let addedCount = 0;
            const now = new Date().toLocaleString();
            const todayDate = new Date().toISOString().slice(0, 10);

            state.history.forEach((rec) => {
                if (!rec.addedToInventory) {
                    rec.batches.forEach((b) => {
                        state.inventory.push({
                            id: 'inv_' + Date.now() + Math.random().toString(36).substr(2, 5),
                            historyBatchId: b.id, inboundDate: rec.date || todayDate, 
                            stockCode: rec.stockCode || state.stockCode, batchCode: b.code, 
                            initialQty: b.amount, currentQty: b.amount, status: "Available" 
                        });
                        state.transactions.unshift({
                            id: 'trx_' + Date.now() + Math.random().toString(36).substr(2, 5),
                            historyBatchId: b.id, timestamp: now, type: "IN", 
                            stockCode: rec.stockCode || state.stockCode, batchCode: b.code, jobNo: "-", amount: b.amount,
                            remarks: "New batch inbound" 
                        });
                        addedCount++;
                    });
                    rec.addedToInventory = true;
                }
            });

            if (addedCount > 0) saveState(); 
            else alert(getMsg("창고에 새로 입고할 미등록 배치가 없습니다.", "No unregistered batches."));
        }

        function updateIssueStockDropdown() {
            const select = document.getElementById("issueStockCode");
            select.innerHTML = `<option value="">${t('opt_sel_stock')}</option>`;
            const availableStocks = [...new Set(state.inventory.filter((i) => i.currentQty > 0).map((i) => i.stockCode))];
            availableStocks.forEach((sc) => { select.innerHTML += `<option value="${sc}">${sc}</option>`; });
            updateBatchDropdown();
        }

        function updateBatchDropdown() {
            const stockCode = document.getElementById("issueStockCode").value;
            const batchSelect = document.getElementById("issueBatchCode");
            const maxLabel = document.getElementById("maxIssueLabel");
            document.getElementById("issueAmount").value = "";

            if (!stockCode) {
                batchSelect.innerHTML = `<option value="">${t('opt_first_stock')}</option>`;
                batchSelect.disabled = true;
                maxLabel.innerText = "";
                return;
            }
            batchSelect.disabled = false;
            batchSelect.innerHTML = `<option value="">${t('opt_sel_batch')}</option>`;

            const availableBatches = state.inventory.filter((i) => i.stockCode === stockCode && i.currentQty > 0);
            availableBatches.forEach((inv) => {
                batchSelect.innerHTML += `<option value="${inv.id}">${inv.batchCode} (${inv.currentQty} Kg)</option>`;
            });
            updateMaxIssueAmount();
        }

        function updateMaxIssueAmount() {
            const invId = document.getElementById("issueBatchCode").value;
            const maxLabel = document.getElementById("maxIssueLabel");
            if (!invId) { maxLabel.innerText = ""; return; }
            const invItem = state.inventory.find((i) => i.id === invId);
            if (invItem) maxLabel.innerText = `${t('msg_max_avail')} ${invItem.currentQty} Kg)`;
        }

        function addIssueJobInput() {
            const container = document.getElementById("issueJobContainer");
            const div = document.createElement("div");
            div.className = "flex items-center space-x-2 mt-2";
            div.innerHTML = `
                <input type="text" class="issue-job-input flex-grow border border-gray-300 rounded-md p-2 focus:ring-red-500 focus:border-red-500" placeholder="${t('ph_job')}" />
                <button onclick="this.parentElement.remove()" class="bg-gray-200 hover:bg-gray-300 text-gray-600 px-3 py-2 rounded-md font-bold transition border border-gray-300">X</button>
            `;
            container.appendChild(div);
        }

        function issueMaterial() {
            const stockCode = document.getElementById("issueStockCode").value;
            const invId = document.getElementById("issueBatchCode").value;
            const amount = Number(document.getElementById("issueAmount").value);
            
            const jobInputs = Array.from(document.querySelectorAll('.issue-job-input')).map(inp => inp.value.trim()).filter(val => val !== "");
            const jobNoString = jobInputs.join(", ");

            if (!stockCode || !invId || amount <= 0) {
                alert(getMsg("항목을 올바르게 선택하고 출고량을 입력하세요.", "Select items correctly and enter issue amount."));
                return;
            }
            if (jobInputs.length === 0 && !confirm(getMsg("Job#가 입력되지 않았습니다. 그래도 이 배치를 출고하시겠습니까?", "Job# is empty. Proceed with issue?"))) {
                return;
            }

            const invItem = state.inventory.find((i) => i.id === invId);
            if (!invItem) return;

            if (amount > invItem.currentQty) {
                alert(getMsg("입력한 출고량이 잔량을 초과합니다.", "Issue amount exceeds remaining batch amount."));
                return;
            }

            invItem.currentQty -= amount;
            invItem.status = invItem.currentQty === 0 ? "Depleted" : "Partial";

            const remarkText = jobNoString ? `Material issue (Job#: ${jobNoString})` : "Material issue (No Job#)";

            state.transactions.unshift({
                id: 'trx_' + Date.now() + Math.random().toString(36).substr(2, 5),
                timestamp: new Date().toLocaleString(), type: "OUT", stockCode: invItem.stockCode,
                batchCode: invItem.batchCode, jobNo: jobNoString || "-", amount: amount, remarks: remarkText
            });

            saveState();
            
            document.getElementById("issueAmount").value = "";
            document.getElementById("issueJobContainer").innerHTML = `
                <div class="flex items-center space-x-2">
                    <input type="text" class="issue-job-input flex-grow block w-full border border-gray-300 rounded-md p-2 focus:ring-red-500 focus:border-red-500" placeholder="${t('ph_job')}" />
                </div>
            `;
            updateIssueStockDropdown();
        }

        function cancelInventoryInbound(index) {
            const rec = state.history[index];
            if (!rec.addedToInventory) return;
            
            const batchIds = rec.batches.map(b => b.id);
            const batchCodes = rec.batches.map((b) => b.code); 
            
            const relatedInventory = state.inventory.filter((inv) => inv.historyBatchId ? batchIds.includes(inv.historyBatchId) : batchCodes.includes(inv.batchCode));
            const isUsed = relatedInventory.some((inv) => inv.currentQty !== inv.initialQty);
            
            if (isUsed) { 
                alert(getMsg("이미 자재가 출고(사용)된 배치는 입고를 취소할 수 없습니다.", "Partially used batches cannot be cancelled.")); 
                return; 
            }
            if (confirm(getMsg("이 생산 기록의 입고를 취소하고 다시 미입고 상태로 되돌리시겠습니까?", "Cancel inbound and revert to pending?"))) {
                state.inventory = state.inventory.filter((inv) => inv.historyBatchId ? !batchIds.includes(inv.historyBatchId) : !batchCodes.includes(inv.batchCode));
                state.transactions = state.transactions.filter((t) => t.historyBatchId ? !batchIds.includes(t.historyBatchId) : !(t.type === "IN" && batchCodes.includes(t.batchCode)));
                rec.addedToInventory = false; 
                saveState();
            }
        }

        function cleanupDepletedInventory() {
            const initialCount = state.inventory.length;
            state.inventory = state.inventory.filter((inv) => inv.currentQty > 0);
            if (initialCount - state.inventory.length > 0) saveState(); 
        }

        function clearAllInventory() {
            secureDestructiveAction(getMsg("전체 재고 삭제", "Delete Inventory"), () => { 
                state.inventory = []; saveState(); updateIssueStockDropdown(); 
            }); 
        }

        function clearTransactionHistory() {
            secureDestructiveAction(getMsg("입출고 기록 삭제", "Clear History"), () => { 
                state.transactions = []; saveState(); 
            }); 
        }

        function toggleAll(type) {
            const isChecked = document.getElementById(`selectAll${type}`).checked;
            document.querySelectorAll(`.${type}-checkbox`).forEach(cb => cb.checked = isChecked);
        }

        function deleteSelectedInventory() {
            const selected = Array.from(document.querySelectorAll('.inv-checkbox:checked')).map(cb => cb.value);
            if (selected.length === 0) return alert(t('msg_no_sel'));
            
            if (confirm(getMsg(`선택한 ${selected.length}개의 재고 항목을 삭제하시겠습니까?`, `Delete ${selected.length} selected inventory items?`))) {
                state.inventory = state.inventory.filter(inv => !selected.includes(inv.id));
                saveState();
                updateIssueStockDropdown();
            }
        }

        function deleteSelectedTransactions() {
            const selected = Array.from(document.querySelectorAll('.trx-checkbox:checked')).map(cb => cb.value);
            if (selected.length === 0) return alert(t('msg_no_sel'));
            
            if (confirm(getMsg(`선택한 ${selected.length}개의 입출고 기록을 삭제하시겠습니까?`, `Delete ${selected.length} selected transaction items?`))) {
                state.transactions = state.transactions.filter(t => !selected.includes(t.id));
                saveState();
            }
        }

