        };
        let erpReference = null; // ERP 데이터를 읽어오기 위한 참조 변수

        function init() {
            document.getElementById("prodDate").valueAsDate = new Date();
            
            // 1. 공통 스토리지에서 데이터 불러오기
            const saved = localStorage.getItem("ctk_unified_state");
            if (saved) {
                const unifiedState = JSON.parse(saved);
                if (unifiedState.mes) state = unifiedState.mes;
                erpReference = unifiedState.erp || null; // ERP 데이터 접근 연결
            } else {
                // 최초 연동 시 기존 MES 데이터 마이그레이션 방어코드
                const oldSaved = localStorage.getItem("batchAppState");
                if (oldSaved) state = JSON.parse(oldSaved);
            }

            if (!state.inventory) state.inventory = [];
            if (!state.transactions) state.transactions = [];
            if (!state.workorders) state.workorders = []; 
            if (!state.timeTracks) state.timeTracks = []; 
            if (!state.blenderData) state.blenderData = null; 
            
            state.inventory.forEach(inv => { if (!inv.id) inv.id = 'inv_' + Date.now() + Math.random().toString(36).substr(2, 5); });
            state.transactions.forEach(t => { if (!t.id) t.id = 'trx_' + Date.now() + Math.random().toString(36).substr(2, 5); });
            
            const elStock = document.getElementById("stockCode"); if (elStock) elStock.value = state.stockCode || "";
            const elTarget = document.getElementById("targetSize"); if (elTarget) elTarget.value = state.targetSize || "";
            const elPlanned = document.getElementById("plannedProd"); if (elPlanned) elPlanned.value = state.plannedProd || "";
            
            applyTranslations();
            updateUI();
            
            setTimeout(() => { initResizableColumns(); }, 500);
        }
               function saveState() {
            const elStock = document.getElementById("stockCode"); if (elStock) state.stockCode = elStock.value;
            const elTarget = document.getElementById("targetSize"); if (elTarget) state.targetSize = Number(elTarget.value);
            const elPlanned = document.getElementById("plannedProd"); if (elPlanned) state.plannedProd = Number(elPlanned.value);
            
            // 2. 공통 스토리지에 MES 데이터 덮어쓰기 (ERP 데이터는 유지)
            let unifiedState = { mes: state, erp: {} };
            const saved = localStorage.getItem("ctk_unified_state");
            if (saved) {
                unifiedState.erp = JSON.parse(saved).erp || {};
            }
            localStorage.setItem("ctk_unified_state", JSON.stringify(unifiedState));
            updateUI();
        }

        // 3. 실시간 동기화: ERP 탭에서 변경 발생 시 MES 즉시 새로고침
        window.addEventListener('storage', function(e) {
            if (e.key === 'ctk_unified_state') {
                init();
            }
        });

