        function addGroupTask() {
            const startNode = document.getElementById("groupStartTime");
            const endNode = document.getElementById("groupEndTime");
            const taskNode = document.getElementById("groupTaskName");
            const jobNode = document.getElementById("groupJobNo");
            const extraNode = document.getElementById("groupExtraWorkers");

            // 1. 필수값 검증
            if (!startNode.value || !endNode.value || !taskNode.value.trim()) {
                alert(getMsg("시작 일시, 종료 일시, 작업명은 필수 입력 항목입니다.", "Start/End time and Task are required."));
                return;
            }

            const startDate = new Date(startNode.value);
            const endDate = new Date(endNode.value);

            if (startDate >= endDate) {
                alert(getMsg("종료 시간이 시작 시간보다 빨라야 합니다.", "End time must be after Start time."));
                return;
            }

            // 2. 선택된 멤버 수집 (체크박스)
            const selectedCheckboxes = document.querySelectorAll('.group-worker-cb:checked');
            const workers = Array.from(selectedCheckboxes).map(cb => cb.value);

            // 3. 직접 텍스트로 입력한 추가 멤버 수집
            if (extraNode.value.trim()) {
                const extras = extraNode.value.split(',').map(w => w.trim()).filter(Boolean);
                workers.push(...extras);
            }

            if (workers.length === 0) {
                alert(getMsg("최소 한 명 이상의 멤버를 선택하거나 추가 입력해주세요.", "Select or enter at least one worker."));
                return;
            }

            // 4. 날짜 포맷팅 (YYYY-MM-DD HH:mm)
            const formatDateTime = (d) => {
                const y = d.getFullYear();
                const m = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                const hh = String(d.getHours()).padStart(2, '0');
                const mm = String(d.getMinutes()).padStart(2, '0');
                return `${y}-${m}-${dd} ${hh}:${mm}`;
            };

            const startTimeStr = formatDateTime(startDate);
            const endTimeStr = formatDateTime(endDate);
            const taskStr = taskNode.value.trim();
            const jobStr = jobNode.value.trim() || "-";

            // 5. 선택된 인원 수만큼 각각 타임 트랙 데이터 생성
            workers.forEach(w => {
                state.timeTracks.push({
                    id: 'tt_' + Date.now() + Math.random().toString(36).substr(2, 5),
                    worker: w,
                    jobNo: jobStr,
                    operation: "Group Production", // 기본 공정 이름 지정
                    task: taskStr,
                    startTime: startTimeStr,
                    endTime: endTimeStr
                });
            });

            // 6. 저장 후 화면 즉시 갱신
            saveState();
            renderTimeTracks();

            alert(getMsg(`${workers.length}명의 멤버에게 [${taskStr}] 일정이 일괄 등록되었습니다.`, `Group task applied to ${workers.length} workers.`));

            // 7. 입력 폼 초기화
            startNode.value = "";
            endNode.value = "";
            taskNode.value = "";
            jobNode.value = "";
            extraNode.value = "";
            selectedCheckboxes.forEach(cb => cb.checked = false);
        }
        // ===================================================
        window.onload = init;
</script>
